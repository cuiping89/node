# 获取控制面板密码
get_dashboard_passcode() {
    jq -r '.dashboard_passcode // empty' "${CONFIG_DIR}/server.json" 2>/dev/null || echo ""
}

# 更新控制面板密码
update_dashboard_passcode() {
    # 读取旧密码
    local old_passcode
    old_passcode=$(jq -r '.dashboard_passcode // "无"' "${CONFIG_DIR}/server.json" 2>/dev/null || echo "无")

    # 获取新密码参数
    local new_passcode="$1"

    # 如果没有提供密码，提示用户输入
    if [[ -z "$new_passcode" ]]; then
        echo -e "${YELLOW}请输入新密码（6-64 位字母或数字），留空则随机生成 12 位：${NC}"
        read -r new_passcode
    fi

    # 【v4.7.0】若留空则自动生成 12 位字母数字（CSPRNG），与安装默认一致
    if [[ -z "$new_passcode" ]]; then
        new_passcode="$(LC_ALL=C tr -dc 'a-z0-9' </dev/urandom | head -c 12)"
        log_info "未输入密码，自动生成: $new_passcode"
    else
        # 【v4.7.0】放宽格式：6-64 位字母或数字。
        # 仅允许 [A-Za-z0-9] 以规避 URL 查询串与 nginx map 引号转义问题；
        # 仍向后兼容旧的 6 位纯数字密码。
        if ! [[ "$new_passcode" =~ ^[A-Za-z0-9]{6,64}$ ]]; then
            log_error "密码格式错误！必须是 6-64 位字母或数字（不含空格或符号）"
            return 1
        fi
    fi

    # v4.6.0-rc4-rc1: 同时轮换 Cookie 秘钥（每次改密码必须废止所有旧 session）
    local new_cookie_secret
    new_cookie_secret=$(head -c 32 /dev/urandom | od -An -tx1 | tr -d ' \n')
    if [[ ${#new_cookie_secret} -ne 64 ]]; then
        log_error "Cookie 秘钥生成失败"
        return 1
    fi

    # 2. 更新 server.json（同时写 passcode 和 cookie_secret）
    local temp_file="${CONFIG_DIR}/server.json.tmp"
    if jq --arg passcode "$new_passcode" --arg secret "$new_cookie_secret" \
         '.dashboard_passcode = $passcode | .dashboard_cookie_secret = $secret' \
         "${CONFIG_DIR}/server.json" > "$temp_file"; then
        mv "$temp_file" "${CONFIG_DIR}/server.json"
        chmod 600 "${CONFIG_DIR}/server.json"
        chown root:root "${CONFIG_DIR}/server.json"
        log_success "server.json 中的密码和 Cookie 秘钥已更新"
    else
        log_error "更新 server.json 失败"
        rm -f "$temp_file"
        return 1
    fi

    # 3. 重写完整的 nginx passcode + cookie conf
    local passcode_conf="/etc/nginx/conf.d/edgebox_passcode.conf"
    cat > "$passcode_conf" << EOF
# 由 edgeboxctl 自动生成于 $(date)
map \$arg_passcode \$pass_ok {
    "${new_passcode}" 1;
    default 0;
}
map \$cookie_ebp \$cookie_ok {
    "${new_cookie_secret}" 1;
    default 0;
}
map \$pass_ok \$set_cookie {
    1 "ebp=${new_cookie_secret}; Path=/traffic/; HttpOnly; Secure; SameSite=Lax; Max-Age=86400";
    0 "";
}
EOF
    chmod 600 "$passcode_conf"
    chown root:root "$passcode_conf"
    log_success "Nginx 密码 + Cookie 配置已更新（所有旧 session 已废止）"

    # 4. 重载 Nginx
    if reload_or_restart_services nginx; then
        log_success "Nginx 配置重载成功"
        log_success "控制面板密码更新成功！新密码：${YELLOW}${new_passcode}${NC}"
        log_info "原密码：${old_passcode:-无}"
        return 0
    else
        log_error "Nginx 重载失败，请检查配置"
        return 1
    fi
}

# 优化后的配置验证函数（替代原来的get_server_info）
get_server_info() {
    ensure_config_loaded || return 1

    # 验证关键配置项
    if [[ -z "$SERVER_IP" || "$SERVER_IP" == "null" ]]; then
        log_error "服务器IP配置缺失"
        return 1
    fi

    # 可选：验证UUID格式
    if [[ -n "$UUID_VLESS_REALITY" ]] && ! [[ "$UUID_VLESS_REALITY" =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]]; then
        log_warn "VLESS Reality UUID格式可能异常"
    fi

    return 0
}


# 异步重启服务并安全退出 (Shortened Delay Version)


ESC=$'\033'
BLUE="${ESC}[0;34m"; PURPLE="${ESC}[0;35m"; CYAN="${ESC}[0;36m"
YELLOW="${ESC}[1;33m"; GREEN="${ESC}[0;32m"; RED="${ESC}[0;31m"; NC="${ESC}[0m"
LOG_FILE="/var/log/edgebox-install.log"

# 注: log_info/log_warn/log_error/log_success 已在文件开头定义，此处不再重复

# v4.6.0-rc4: 严格的服务重载/重启 (审核 P1#5)
# 旧版本: 无条件返回 0，掩盖 systemctl restart 失败
# 新版本: reload 或 restart 任一失败即返回 1
reload_or_restart_services() {
  local services=("$@")
  local failed=0
  for svc in "${services[@]}"; do
    # v4.7.0 修复: sing-box 不支持信号热重载配置（SIGHUP 不重读配置），必须 restart，
    #   否则 obfs / 证书 / UDP 等变更只写进文件、不在运行进程里生效（曾导致 obfs 没真正启用）。
    if [[ "$svc" == "sing-box" || "$svc" == "sing-box.service" ]]; then
      if command -v sing-box >/dev/null 2>&1 && [[ -f "${CONFIG_DIR}/sing-box.json" ]] \
         && ! sing-box check -c "${CONFIG_DIR}/sing-box.json" >/dev/null 2>&1; then
        log_error "sing-box 配置校验失败，跳过重启（避免把坏配置重启进进程）"
        failed=1; continue
      fi
      if systemctl restart "$svc" 2>/dev/null; then
        log_info "$svc 已重启"
      else
        log_error "$svc 重启失败"
        systemctl status "$svc" --no-pager -l 2>&1 | tail -20 || true
        failed=1
      fi
      continue
    fi
    if systemctl reload "$svc" 2>/dev/null; then
      log_info "$svc 已热加载"
    elif systemctl restart "$svc" 2>/dev/null; then
      log_info "$svc 已重启"
    else
      log_error "$svc 重载和重启均失败"
      systemctl status "$svc" --no-pager -l 2>&1 | tail -20 || true
      failed=1
    fi
  done
  return $failed
}

