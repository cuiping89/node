# 清空 nftables 的代理采集集合（VPS 全量出站时用）
flush_nft_resi_sets() {
  nft flush set inet edgebox resi_addr4 2>/dev/null || true
  nft flush set inet edgebox resi_addr6 2>/dev/null || true
}

# 解析代理 URL => 导出全局变量：
parse_proxy_url() {
  local url
  url="$(printf '%s' "$1" | tr -d '\r' | sed -E 's/^[[:space:]]+|[[:space:]]+$//g')"
  [[ -z "$url" ]] && { echo "空代理地址"; return 1; }

  PROXY_SCHEME="${url%%://*}"; PROXY_SCHEME="${PROXY_SCHEME%:*}"
  local rest="${url#*://}" auth hostport query
  [[ "$rest" == *\?* ]] && { query="${rest#*\?}"; rest="${rest%%\?*}"; }
  if [[ "$rest" == *@* ]]; then
    auth="${rest%@*}"; hostport="${rest#*@}"
    PROXY_USER="${auth%%:*}"; PROXY_PASS="${auth#*:}"; [[ "$PROXY_PASS" == "$auth" ]] && PROXY_PASS=""
  else
    hostport="$rest"; PROXY_USER=""; PROXY_PASS=""
  fi
  PROXY_HOST="${hostport%%:*}"; PROXY_PORT="${hostport##*:}"
  PROXY_TLS=0; PROXY_SNI=""

  case "$PROXY_SCHEME" in
    http)   PROXY_TLS=0 ;;
    https)  PROXY_SCHEME="http"; PROXY_TLS=1 ;;
    socks|socks5) PROXY_SCHEME="socks"; PROXY_TLS=0 ;;
    socks5s)      PROXY_SCHEME="socks"; PROXY_TLS=1 ;;
    *) echo "不支持的代理协议: $PROXY_SCHEME"; return 1;;
  esac

  if [[ -n "$query" ]]; then
    local kv k v; IFS='&' read -r -a kv <<<"$query"
    for k in "${kv[@]}"; do v="${k#*=}"; k="${k%%=*}"; [[ "$k" == "sni" ]] && PROXY_SNI="$v"; done
  fi
}

# 用 curl 健康检查（http/https/socks 都支持）
check_proxy_health_url() {
  parse_proxy_url "$1" || return 1
  local auth="" proxy_uri=""
  [[ -n "$PROXY_USER" ]] && auth="${PROXY_USER}:${PROXY_PASS}@"
  if [[ "$PROXY_SCHEME" == "http" ]]; then
    local scheme="http"; [[ "$PROXY_TLS" -eq 1 ]] && scheme="https"
    proxy_uri="${scheme}://${auth}${PROXY_HOST}:${PROXY_PORT}"
  else
    proxy_uri="socks5h://${auth}${PROXY_HOST}:${PROXY_PORT}"
  fi
  curl -fsS --max-time 6 --connect-timeout 4 --proxy "$proxy_uri" \
       http://www.gstatic.com/generate_204 >/dev/null
}

# === Anchor-1 INSERT BEGIN : 验收报告函数 ===


get_current_cert_mode(){
  if [[ -f "${CONFIG_DIR}/cert_mode" ]]; then
    cat "${CONFIG_DIR}/cert_mode"
  else
    echo "self-signed"
  fi
}

post_switch_report() {
  : "${CYAN:=}"; : "${GREEN:=}"; : "${RED:=}"; : "${YELLOW:=}"; : "${NC:=}"

  echo -e "\n${CYAN}--- 切换证书/模式后 · 自动验收报告 ---${NC}"

  # 1) Nginx 配置测试
  echo -e "${CYAN}1) Nginx 配置测试 · 详细输出:${NC}"
  local _nginx_out _rc
  _nginx_out="$(nginx -t 2>&1)"; _rc=$?
  echo "${_nginx_out}" | sed 's/^/   | /'
  echo -n "   => 结果: "; [[ $_rc -eq 0 ]] && echo -e "${GREEN}OK${NC}" || echo -e "${RED}FAIL${NC}"

  # 2) 服务可用性
  echo -e "${CYAN}2) 服务可用性:${NC}"
  for s in xray sing-box nginx; do
    if systemctl is-active --quiet "$s"; then
      echo -e "   - ${s}: ${GREEN}active${NC}"
    else
      echo -e "   - ${s}: ${RED}inactive${NC}"
    fi
  done

  # 3) 证书链与到期
  echo -e "${CYAN}3) 证书链与到期:${NC}"
  local mode pem key domain
  mode="$(get_current_cert_mode)"
  if [[ "$mode" == self-signed ]]; then
    pem="${CERT_DIR}/current.pem"; key="${CERT_DIR}/current.key"
  else
    domain="${mode##*:}"
    pem="/etc/letsencrypt/live/${domain}/fullchain.pem"
    key="/etc/letsencrypt/live/${domain}/privkey.pem"
  fi
  if [[ -f "$pem" && -f "$key" ]]; then
    local exp
    exp="$(openssl x509 -in "$pem" -noout -enddate 2>/dev/null | cut -d= -f2 || true)"
    [[ -n "$exp" ]] && echo "   - 到期时间: $exp" || echo "   - 无法读取到期时间"
  else
    echo -e "   - ${RED}证书文件缺失${NC} (${pem} / ${key})"
  fi

  # 3b) 域名解析核对（LE 模式才做）
  if [[ -n "$domain" ]]; then
    local a_ip srv_ip
    a_ip="$(getent ahostsv4 "$domain" 2>/dev/null | awk '{print $1; exit}')"
    srv_ip="$(jq -r '.server_ip // empty' ${CONFIG_DIR}/server.json 2>/dev/null)"
    echo -e "   - A 记录: ${a_ip:-?}  | server_ip: ${srv_ip:-?}"
    if [[ -n "$a_ip" && -n "$srv_ip" && "$a_ip" == "$srv_ip" ]]; then
      echo -e "   => 解析一致：${GREEN}OK${NC}"
    else
      echo -e "   => ${YELLOW}解析与 server_ip 不一致（如前置 CDN 可忽略）${NC}"
    fi
  fi

  # 4) 证书软链
  echo -e "${CYAN}4) 证书软链:${NC}"
  ls -l "${CERT_DIR}/current.pem" "${CERT_DIR}/current.key" 2>/dev/null | sed 's/^/   | /' || true
  [[ -L ${CERT_DIR}/current.pem && -L ${CERT_DIR}/current.key ]] \
    && echo -e "   => ${GREEN}软链存在${NC}" || echo -e "   => ${RED}软链缺失${NC}"

  # 5) 证书权限
  echo -e "${CYAN}5) 证书权限:${NC}"
  local perm_line perm
  perm_line="$(stat -L -c '%a %U:%G %n' "${CERT_DIR}/current.key" 2>/dev/null || true)"
  [[ -n "$perm_line" ]] && echo "   | $perm_line"
  perm="$(printf '%s\n' "$perm_line" | awk '{print $1}')"
  if [[ "$perm" == "600" || "$perm" == "640" ]]; then
    echo -e "   => ${GREEN}已收紧${NC}"
  else
    echo -e "   => ${YELLOW}建议运行：edgeboxctl fix-permissions${NC}"
  fi

  echo -e "${CYAN}--------------------------------${NC}\n"
}

# === [NEW] Unified function to refresh all frontend data sources ===


post_shunt_report() {
  local mode="$1" url="$2"
  : "${CYAN:=}"; : "${GREEN:=}"; : "${RED:=}"; : "${YELLOW:=}"; : "${NC:=}"

  echo -e "\n${CYAN}----- 出站分流配置 · 验收报告: ${YELLOW:=}${mode} ${CYAN}-----${NC}"

  local all_ok=true
  local check_result=""

  # --- Checks 1, 2, 3 (Immediate Feedback) ---

  # 1) Upstream Connectivity
  if [[ -n "$url" ]]; then
    if check_proxy_health_url "$url"; then
      check_result+="${GREEN}✅ 1) 上游代理连通性: OK (代理可正常工作)${NC}\n"
    else
      check_result+="${RED}❌ 1) 上游代理连通性: FAIL (代理无法连接)${NC}\n"
      all_ok=false
    fi
  else
    check_result+="${GREEN}✅ 1) 上游代理连通性: (VPS 模式，跳过)${NC}\n"
  fi

  # 2) Xray Routing Rules
  if [[ "$mode" == "VPS 全量出站" ]]; then
    if jq -e '(.outbounds | length) == 1 and .outbounds[0].tag == "direct"' "${CONFIG_DIR}/xray.json" >/dev/null 2>&1; then
      check_result+="${GREEN}✅ 2) Xray 路由规则:   默认出口 -> direct (已生效)${NC}\n"
    else
      check_result+="${RED}❌ 2) Xray 路由规则:   配置异常，仍存在代理出口！${NC}\n"
      all_ok=false
    fi
  else
    if jq -e '.routing.rules[] | select(.outboundTag == "resi-proxy")' "${CONFIG_DIR}/xray.json" >/dev/null 2>&1; then
      check_result+="${GREEN}✅ 2) Xray 路由规则:   默认出口 -> resi-proxy (已生效)${NC}\n"
    else
      check_result+="${RED}❌ 2) Xray 路由规则:   配置失败！未能写入代理规则。${NC}\n"
      all_ok=false
    fi
  fi

  # 3) DNS Resolution Mode
  if jq -e '.dns.servers[] | select(.outboundTag == "resi-proxy")' "${CONFIG_DIR}/xray.json" >/dev/null 2>&1; then
    check_result+="${GREEN}✅ 3) DNS 解析模式:    经由代理 (DoH)${NC}\n"
  else
    check_result+="${GREEN}✅ 3) DNS 解析模式:    直连解析${NC}\n"
  fi

  # Print immediate results
  echo -e "$check_result"

  # --- Check 4 (Wait and Verify) ---
  echo -n "   4) 服务健康状态:   等待服务稳定..."
  
  local services_ok=true
  local final_status_line=""
  local timeout=15
  local start_time=$(date +%s)
  
  for svc in nginx xray; do
      while true; do
          if systemctl is-active --quiet "$svc"; then
              break
          fi
          local current_time=$(date +%s)
          if (( current_time - start_time > timeout )); then
              echo -e "\r${RED}❌ 4) 服务健康状态:   nginx: $(systemctl is-active nginx), xray: $(systemctl is-active xray) (等待 ${svc} 超时)${NC}"
              services_ok=false
              break 2 # Break outer loop
          fi
          echo -n "."
          sleep 1
      done
  done

  if [[ "$services_ok" == "true" ]]; then
      echo -e "\r${GREEN}✅ 4) 服务健康状态:   nginx: active, xray: active                     ${NC}"
  else
      all_ok=false
  fi

  # --- Final Conclusion ---
  echo "" # Add a blank line for spacing
  if [[ "$all_ok" == "true" ]]; then
    if [[ "$mode" == "VPS 全量出站" ]]; then
      echo -e "结论: ${GREEN}✅ 配置成功！Xray 的出站流量已全部恢复为VPS直连。${NC}"
    else
      echo -e "结论: ${GREEN}✅ 配置成功！Xray 的出站流量已按预期切换。${NC}"
    fi
  else
    echo -e "结论: ${RED}❌ 配置失败！请根据上面的错误提示检查相关服务日志。${NC}"
  fi
  echo -e "${CYAN}-------------------------------------------------${NC}\n"
}


# === Anchor-1 INSERT END ===

# 生成 Xray 的代理 outbound JSON（单个）
build_xray_resi_outbound() {
  local users='' stream=''
  [[ -n "$PROXY_USER" ]] && users=", \"users\":[{\"user\":\"$PROXY_USER\",\"pass\":\"$PROXY_PASS\"}]"
  if [[ "$PROXY_TLS" -eq 1 ]]; then
    stream=", \"streamSettings\": {\"security\":\"tls\"$( [[ -n "$PROXY_SNI" ]] && echo ",\"tlsSettings\":{\"serverName\":\"$PROXY_SNI\"}" )}"
  fi
  if [[ "$PROXY_SCHEME" == "http" ]]; then
    cat <<JSON
{ "protocol":"http","tag":"resi-proxy","settings":{"servers":[{"address":"$PROXY_HOST","port":$PROXY_PORT$users}]}$stream }
JSON
  else
    cat <<JSON
{ "protocol":"socks","tag":"resi-proxy","settings":{"servers":[{"address":"$PROXY_HOST","port":$PROXY_PORT$users}]}$stream }
JSON
  fi
}

setup_shunt_directories() {
    mkdir -p "${CONFIG_DIR}/shunt" 2>/dev/null || true
    if [[ ! -f "${CONFIG_DIR}/shunt/whitelist.txt" ]]; then
        echo "$WHITELIST_DOMAINS" | tr ',' '\n' > "${CONFIG_DIR}/shunt/whitelist.txt"
    fi
    if [[ ! -f "$SHUNT_CONFIG" ]]; then
        echo '{"mode":"vps","proxy_info":"","last_check":"","health":"unknown"}' > "$SHUNT_CONFIG"
    fi
}

update_shunt_state() {
    local mode="$1"
    local proxy_info="$2"
    local health="${3:-unknown}"
    local timestamp=$(date -Iseconds)
    echo "{\"mode\":\"$mode\",\"proxy_info\":\"$proxy_info\",\"last_check\":\"$timestamp\",\"health\":\"$health\"}" > "$SHUNT_CONFIG"
}

show_shunt_status() {
    echo -e "\n${CYAN}出站分流状态：${NC}"
    setup_shunt_directories
    
    # 定义所需文件路径
    local state_file="${CONFIG_DIR}/shunt/state.json"
    local ipq_file="/var/www/edgebox/status/ipq_proxy.json"
    local whitelist_file="${CONFIG_DIR}/shunt/whitelist.txt"

    if [[ -f "$state_file" ]]; then
        local mode=$(jq -r '.mode' "$state_file" 2>/dev/null || echo "vps")
        local proxy_info=$(jq -r '.proxy_info' "$state_file" 2>/dev/null || echo "")

        case "$mode" in
            vps) 
                echo -e "  当前模式: ${GREEN}VPS全量出${NC}"
                echo -e "  说    明: 所有出站流量均使用服务器自身IP地址。"
                echo -e "  提    示: 使用 'edgeboxctl shunt resi <URL>' 可切换至代理模式。"
                ;;
            resi)
                echo -e "  当前模式: ${YELLOW}代理IP全量出${NC}"
                echo -e "  代理信息: ${proxy_info}"
                
                # 读取并显示IP质量信息
                if [[ -f "$ipq_file" ]]; then
                    local ipq_score=$(jq -r '.score // "N/A"' "$ipq_file")
                    local ipq_grade=$(jq -r '.grade // "N/A"' "$ipq_file")
                    local ipq_ip=$(jq -r '.ip // "检测中..."' "$ipq_file")
                    echo -e "  出站 IP:  ${ipq_ip}"
                    echo -e "  IP 质量:  得分 ${ipq_score}, 等级 ${ipq_grade} (${YELLOW}结果稍后自动更新${NC})"
                else
                    echo -e "  IP 质量:  正在检测..."
                fi
                echo -e "  提    示: 使用 'edgeboxctl shunt vps' 可切换回直连模式。"
                ;;
            direct_resi)
                echo -e "  当前模式: ${BLUE}智能分流${NC}"
                echo -e "  代理信息: ${proxy_info}"
                
                # 读取并显示IP质量信息
                if [[ -f "$ipq_file" ]]; then
                    local ipq_score=$(jq -r '.score // "N/A"' "$ipq_file")
                    local ipq_grade=$(jq -r '.grade // "N/A"' "$ipq_file")
                    local ipq_ip=$(jq -r '.ip // "检测中..."' "$ipq_file")
                    echo -e "  代理出站 IP: ${ipq_ip}"
                    echo -e "  IP 质量:     得分 ${ipq_score}, 等级 ${ipq_grade} (${YELLOW}结果稍后自动更新${NC})"
                else
                    echo -e "  IP 质量:     正在检测..."
                fi

                # 显示白名单信息
                local wl_count=$(wc -l < "$whitelist_file" 2>/dev/null || echo "0")
                echo -e "  白名单规则: 共 ${wl_count} 条。匹配域名走VPS直连，其余走代理。"
                echo -e "  提      示: 使用 'edgeboxctl shunt whitelist list' 查看完整列表。"
                ;;
        esac
    else
        echo -e "  当前模式: ${GREEN}VPS全量出（默认）${NC}"
        echo -e "  说    明: 所有出站流量均使用服务器自身IP地址。"
    fi
    
    # 在后台触发一次IP质量更新，不阻塞当前命令
    if [[ -x /usr/local/bin/edgebox-ipq.sh ]]; then
        ( /usr/local/bin/edgebox-ipq.sh >/dev/null 2>&1 & )
    fi
}


ensure_xray_dns_alignment() {
  local cfg="/etc/edgebox/config/xray.json"
  local tmp="$(mktemp)"
  [[ -f "$cfg" ]] || { log_warn "未找到 $cfg，跳过 Xray DNS 对齐"; return 0; }

  # 探测是否处于代理出站模式
  local mode="vps"
  if [[ -f /etc/edgebox/config/shunt/state.json ]]; then
    local state_mode=$(jq -r '.mode' /etc/edgebox/config/shunt/state.json 2>/dev/null)
    [[ "$state_mode" == "resi" || "$state_mode" == "direct-resi" ]] && mode="resi"
  fi

  if [[ "$mode" == "resi" ]]; then
    log_info "DNS 对齐：检测到代理出站，将 DNS 也走代理"
    jq '
      .dns.servers = [
        {"address":"https://1.1.1.1/dns-query","outboundTag":"resi-proxy"},
        {"address":"https://8.8.8.8/dns-query","outboundTag":"resi-proxy"}
      ] |
      .routing.rules = (
        (.routing.rules // []) |
        map(select(.port != "53")) |
        [{"type":"field","port":"53","outboundTag":"resi-proxy"}] + .
      )
    ' "$cfg" > "$tmp" \
    && /usr/local/bin/xray -test -format json -c "$tmp" \
    && mv "$tmp" "$cfg" || {
      rm -f "$tmp";
      log_error "写入 Xray DNS(代理) 失败（新配置未通过自检或落盘失败，未覆盖原配置）";
      return 1;
    }
  else
    log_info "DNS 对齐：检测到 VPS 直出，将 DNS 设为直连"
    jq '
      .dns.servers = [
        "8.8.8.8", "1.1.1.1",
        {"address":"https://1.1.1.1/dns-query"},
        {"address":"https://8.8.8.8/dns-query"}
      ] |
      .routing.rules = (
        (.routing.rules // []) |
        map(select(.port != "53"))
      )
    ' "$cfg" > "$tmp" \
    && /usr/local/bin/xray -test -format json -c "$tmp" \
    && mv "$tmp" "$cfg" || {
      rm -f "$tmp";
      log_error "写入 Xray DNS(直连) 失败（新配置未通过自检或落盘失败，未覆盖原配置）";
      return 1;
    }
  fi

  systemctl reload xray 2>/dev/null || systemctl restart xray 2>/dev/null || true
}


setup_outbound_vps() {
    log_info "配置VPS全量出站模式..."
    get_server_info || return 1
    local xray_tmp="${CONFIG_DIR}/xray.json.tmp"
    jq '.outbounds = [ { "protocol":"freedom", "tag":"direct" } ] | .routing = { "rules": [] }' "${CONFIG_DIR}/xray.json" > "$xray_tmp" && mv "$xray_tmp" "${CONFIG_DIR}/xray.json"
    chmod 600 "${CONFIG_DIR}/xray.json"; chown root:root "${CONFIG_DIR}/xray.json"
    setup_shunt_directories
update_shunt_state "vps" "" "healthy"
flush_nft_resi_sets
ensure_xray_dns_alignment # 确保DNS也切换回直连
log_info "正在应用配置并重启服务..."
reload_or_restart_services nginx xray sing-box # 使用同步重启

log_info "服务重启完成，开始生成验收报告..."
post_shunt_report "VPS 全量出站" "" # 移到最后执行

bash /etc/edgebox/scripts/dashboard-backend.sh --now >/dev/null 2>&1 || true
}

setup_outbound_resi() {
  local url="$1"
  [[ -z "$url" ]] && { echo "用法: edgeboxctl shunt resi '<URL>'"; return 1; }
  
  log_info "配置代理IP全量出站: ${url}"
  if ! check_proxy_health_url "$url"; then 
    log_error "代理不可用：$url"; 
    return 1; 
  fi
  
  get_server_info || return 1
  parse_proxy_url "$url"
  local xob
  xob="$(build_xray_resi_outbound)"
  
  # 🔥 关键修复：DNS也走代理
  jq --argjson ob "$xob" '
    .outbounds=[{"protocol":"freedom","tag":"direct"}, $ob] | 
    .routing={
      "domainStrategy":"AsIs",
      "rules":[
        {"type":"field","port":"53","outboundTag":"resi-proxy"},  # 改为resi-proxy
        {"type":"field","network":"tcp,udp","outboundTag":"resi-proxy"}
      ]
    } |
    .dns.servers=[
      {"address":"https://1.1.1.1/dns-query","outboundTag":"resi-proxy"},
      {"address":"https://8.8.8.8/dns-query","outboundTag":"resi-proxy"}
    ]
  ' ${CONFIG_DIR}/xray.json > ${CONFIG_DIR}/xray.json.tmp && \
  mv ${CONFIG_DIR}/xray.json.tmp ${CONFIG_DIR}/xray.json
  chmod 600 "${CONFIG_DIR}/xray.json" 2>/dev/null; chown root:root "${CONFIG_DIR}/xray.json" 2>/dev/null
  
  echo "$url" > "${CONFIG_DIR}/shunt/resi.conf"
  setup_shunt_directories
update_shunt_state "resi" "$url" "healthy"
ensure_xray_dns_alignment
log_info "正在应用配置并重启服务..."
reload_or_restart_services nginx xray # 使用同步重启

log_info "服务重启完成，开始生成验收报告..."
post_shunt_report "代理全量（Xray-only）" "$url" # 移到最后执行

bash /etc/edgebox/scripts/dashboard-backend.sh --now >/dev/null 2>&1 || true
}

setup_outbound_direct_resi() {
  local url="$1"
  [[ -z "$url" ]] && { echo "用法: edgeboxctl shunt direct-resi '<URL>'"; return 1; }
  log_info "配置智能分流（白名单直连，其余代理）: ${url}"
  if ! check_proxy_health_url "$url"; then log_error "代理不可用：$url"; return 1; fi
  get_server_info || return 1; setup_shunt_directories
  parse_proxy_url "$url"
  local xob wl; xob="$(build_xray_resi_outbound)"
  wl='[]'
  [[ -s "${CONFIG_DIR}/shunt/whitelist.txt" ]] && wl="$(cat "${CONFIG_DIR}/shunt/whitelist.txt" | jq -R -s 'split("\n")|map(select(length>0))|map("domain:"+.)')"
  jq --argjson ob "$xob" --argjson wl "$wl" '.outbounds=[{"protocol":"freedom","tag":"direct"}, $ob] | .routing={"domainStrategy":"AsIs","rules":[{"type":"field","port":"53","outboundTag":"direct"},{"type":"field","domain":$wl,"outboundTag":"direct"},{"type":"field","network":"tcp,udp","outboundTag":"resi-proxy"}]}' ${CONFIG_DIR}/xray.json > ${CONFIG_DIR}/xray.json.tmp && mv ${CONFIG_DIR}/xray.json.tmp ${CONFIG_DIR}/xray.json
  chmod 600 "${CONFIG_DIR}/xray.json" 2>/dev/null; chown root:root "${CONFIG_DIR}/xray.json" 2>/dev/null
  # sing-box remains direct
  echo "$url" > "${CONFIG_DIR}/shunt/resi.conf"
update_shunt_state "direct-resi" "$url" "healthy"
ensure_xray_dns_alignment
log_info "正在应用配置并重启服务..."
reload_or_restart_services nginx xray # 使用同步重启

log_info "服务重启完成，开始生成验收报告..."
post_shunt_report "智能分流（白名单直连）" "$url" # 移到最后执行

bash /etc/edgebox/scripts/dashboard-backend.sh --now >/dev/null 2>&1 || true
}

manage_whitelist() {
    local action="$1"
    shift # "吃掉"第一个参数(add/remove/list)，剩下的 $@ 就是域名列表

    local domains=("$@")
    local needs_refresh=false
    local changes_made=0
    local whitelist_file="${CONFIG_DIR}/shunt/whitelist.txt"

    setup_shunt_directories

    # 对需要参数的命令进行检查
    if [[ ("$action" == "add" || "$action" == "remove") && ${#domains[@]} -eq 0 ]]; then
        echo "用法: edgeboxctl shunt whitelist $action <domain1> [domain2] [...]"
        return 1
    fi

    case "$action" in
        add)
            for domain in "${domains[@]}"; do
                # 跳过空的参数
                if [[ -z "$domain" ]]; then continue; fi
                
                # 检查域名是否已存在
                if ! grep -Fxq "$domain" "$whitelist_file" 2>/dev/null; then
                    echo "$domain" >> "$whitelist_file"
                    log_success "已添加: $domain"
                    ((changes_made++))
                else
                    log_warn "已存在，跳过: $domain"
                fi
            done
            if [[ $changes_made -gt 0 ]]; then
                needs_refresh=true
            fi
            ;;

        remove)
            local tmp_file=$(mktemp)
            cp "$whitelist_file" "$tmp_file"

            for domain in "${domains[@]}"; do
                if [[ -z "$domain" ]]; then continue; fi
                
                # 检查域名是否存在于文件中
                if grep -Fxq "$domain" "$tmp_file" 2>/dev/null; then
                    # 从临时文件中删除该行
                    grep -v -x -F "$domain" "$tmp_file" > "${tmp_file}.new" && mv "${tmp_file}.new" "$tmp_file"
                    log_success "已移除: $domain"
                    ((changes_made++))
                else
                    log_warn "不存在，跳过: $domain"
                fi
            done

            if [[ $changes_made -gt 0 ]]; then
                # 如果有变更，则用修改后的临时文件覆盖原文件
                mv "$tmp_file" "$whitelist_file"
                needs_refresh=true
            else
                # 如果没有任何变更，删除临时文件
                rm -f "$tmp_file"
            fi
            ;;

        list)
            echo -e "${CYAN}白名单域名：${NC}"
            if [[ -f "$whitelist_file" && -s "$whitelist_file" ]]; then
                cat "$whitelist_file" | nl -w2 -s'. '
            else
                echo "  (空)"
            fi
            ;;

        reset)
            echo "$WHITELIST_DOMAINS" | tr ',' '\n' > "$whitelist_file"
            log_success "已重置白名单为默认值"
            needs_refresh=true
            ;;

        *)
            echo "用法: edgeboxctl shunt whitelist [add|remove|list|reset] [domain...]"
            return 1
            ;;
    esac

    # 如果有任何增、删、重置操作，则刷新前端面板
    if [[ "$needs_refresh" == "true" ]]; then
        log_info "正在刷新控制面板数据以应用白名单变更..."
        bash /etc/edgebox/scripts/dashboard-backend.sh --now >/dev/null 2>&1 || log_warn "面板数据刷新失败，将在下个周期自动更新。"
        log_success "控制面板已刷新。"
    fi
}

#############################################
# 流量统计
#############################################



# >>> traffic_show begin
traffic_show() {
  echo -e "流量统计（基于 vnStat）："

  # 选网卡：参数 > 默认路由 > vnstat数据库
  local nic="${1:-$(ip -o route get 1.1.1.1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="dev"){print $(i+1);exit}}')}"
  [[ -z "$nic" ]] && nic="$(vnstat --dbiflist 2>/dev/null | head -n1)"
  [[ -z "$nic" ]] && { echo "  无法确定网卡"; return 1; }

  # 依赖
  command -v vnstat >/dev/null || { echo "  vnstat 未安装"; return 1; }
  command -v jq >/dev/null     || { echo "  jq 未安装"; return 1; }

  # 拉 JSON（限制只取最新 1 条）
  local dj mj
  dj="$(vnstat -i "$nic" --json d 1 2>/dev/null)" || { echo "  无法获取今日数据"; return 1; }
  mj="$(vnstat -i "$nic" --json m 1 2>/dev/null)" || { echo "  无法获取本月数据"; return 1; }

  # 直接按“字节”读取（vnStat --json 的 rx/tx 默认就是 bytes）
  local today_tx today_rx month_tx month_rx
  today_tx="$(jq -r '( .interfaces[0].traffic.day // .interfaces[0].traffic.days )[0].tx // 0' <<<"$dj")"
  today_rx="$(jq -r '( .interfaces[0].traffic.day // .interfaces[0].traffic.days )[0].rx // 0' <<<"$dj")"
  month_tx="$(jq -r '( .interfaces[0].traffic.month // .interfaces[0].traffic.months )[0].tx // 0' <<<"$mj")"
  month_rx="$(jq -r '( .interfaces[0].traffic.month // .interfaces[0].traffic.months )[0].rx // 0' <<<"$mj")"

  # 无依赖友好格式化（字节 -> B/KiB/MiB/GiB/TiB）
  _fmt_bytes() {
    awk -v b="$1" 'BEGIN{
      if (b<0 || b=="") b=0
      u[0]="B";u[1]="KiB";u[2]="MiB";u[3]="GiB";u[4]="TiB"
      i=0; while (b>=1024 && i<4) { b/=1024; i++ }
      if (b==0 || b>=100) printf("%.0f%s", b, u[i]);
      else if (b>=10)     printf("%.1f%s", b, u[i]);
      else                printf("%.2f%s", b, u[i]);
    }'
  }

  echo "  接口： $nic"
  echo "  今日流量： $(_fmt_bytes "$today_tx") ↑ / $(_fmt_bytes "$today_rx") ↓"
  echo "  本月流量： $(_fmt_bytes "$month_tx") ↑ / $(_fmt_bytes "$month_rx") ↓"
}
# <<< traffic_show end


#############################################
# 预警配置 (v4.6.0-rc4-rc1 拆分版)
#  - 机密 → /etc/edgebox/config/alert.env (root 600)
#  - 公共阈值 → /etc/edgebox/traffic/alert-public.json (web-readable)
#############################################
ALERT_ENV="${CONFIG_DIR}/alert.env"
ALERT_PUB="${TRAFFIC_DIR}/alert-public.json"

ensure_alert_conf(){
  [[ -d "$CONFIG_DIR" ]]  || mkdir -p "$CONFIG_DIR"
  [[ -d "$TRAFFIC_DIR" ]] || mkdir -p "$TRAFFIC_DIR"
  if [[ ! -s "$ALERT_ENV" ]]; then
    cat >"$ALERT_ENV" <<'CONF'
# EdgeBox 告警秘钥配置 — 仅 root 可读
ALERT_TG_BOT_TOKEN=
ALERT_TG_CHAT_ID=
ALERT_DISCORD_WEBHOOK=
ALERT_PUSHPLUS_TOKEN=
ALERT_WEBHOOK=
ALERT_WEBHOOK_FORMAT=raw
ALERT_EMAIL=
CONF
    chmod 600 "$ALERT_ENV"
    chown root:root "$ALERT_ENV" 2>/dev/null || true
  fi
  if [[ ! -s "$ALERT_PUB" ]]; then
    cat >"$ALERT_PUB" <<'CONF'
{"monthly_gib": 200, "steps": [30, 60, 90]}
CONF
    chmod 644 "$ALERT_PUB"
  fi
}

# 帮手：把 KEY=VAL 写回 alert.env（用 awk 安全替换，不用 sed）
_alert_env_set(){
  ensure_alert_conf
  local key="$1"; shift
  local val="$*"
  local tmp="${ALERT_ENV}.tmp"
  awk -v K="$key" -v V="$val" '
    BEGIN{found=0}
    {
      if ($0 ~ "^"K"=") { print K"="V; found=1 }
      else print
    }
    END { if (!found) print K"="V }
  ' "$ALERT_ENV" > "$tmp" && mv "$tmp" "$ALERT_ENV"
  chmod 600 "$ALERT_ENV"
  chown root:root "$ALERT_ENV" 2>/dev/null || true
}

# 帮手：把字段写回 alert-public.json
_alert_pub_set(){
  ensure_alert_conf
  local key="$1"; local val="$2"  # val 是 jq 表达式（数字或数组）
  local tmp="${ALERT_PUB}.tmp"
  jq ".${key} = ${val}" "$ALERT_PUB" > "$tmp" 2>/dev/null && mv "$tmp" "$ALERT_PUB"
  chmod 644 "$ALERT_PUB"
}

alert_show(){
  ensure_alert_conf
  echo -e "${CYAN}流量预警配置：${NC}"
  echo "  ── 公共阈值 (${ALERT_PUB}) ──"
  jq -r '. | "  monthly_gib: \(.monthly_gib)\n  steps:       \(.steps | join(\",\"))%"' "$ALERT_PUB" 2>/dev/null
  echo "  ── 通知渠道 (机密，仅显示是否配置) ──"
  # v4.6.0-rc4 (审核 P1#4): 不再 source alert.env，用 grep 安全检测字段是否非空
  _has_value() {
    local key="$1"
    # 匹配 ^KEY=非空内容（容忍引号），但不解释内容
    grep -qE "^${key}=[\"']?[^\"' ]" "$ALERT_ENV" 2>/dev/null
  }
  local tg_ok=未配置 disc_ok=未配置 wx_ok=未配置 wh_ok=未配置
  if _has_value ALERT_TG_BOT_TOKEN && _has_value ALERT_TG_CHAT_ID; then tg_ok=已配置; fi
  _has_value ALERT_DISCORD_WEBHOOK && disc_ok=已配置
  _has_value ALERT_PUSHPLUS_TOKEN  && wx_ok=已配置
  _has_value ALERT_WEBHOOK         && wh_ok=已配置
  printf "  %-12s %s\n" "Telegram:"  "$tg_ok"
  printf "  %-12s %s\n" "Discord:"   "$disc_ok"
  printf "  %-12s %s\n" "微信(PP):"  "$wx_ok"
  printf "  %-12s %s\n" "Webhook:"   "$wh_ok"
}

alert_set_monthly(){
  [[ "$1" =~ ^[0-9]+$ ]] || { log_error "月度预算需为整数GiB"; return 1; }
  _alert_pub_set "monthly_gib" "$1"
  log_success "已设置预算：$1 GiB"
}

alert_set_steps(){
  [[ "$1" =~ ^[0-9]+(,[0-9]+)*$ ]] || { log_error "阈值格式: 30,60,90"; return 1; }
  # 转成 JSON 数组
  local arr="[$1]"
  _alert_pub_set "steps" "$arr"
  log_success "已设置阈值：$1%"
}

alert_set_telegram(){
  [[ -z "$1" || -z "$2" ]] && { log_error "用法: edgeboxctl alert telegram <bot_token> <chat_id>"; return 1; }
  _alert_env_set "ALERT_TG_BOT_TOKEN" "$1"
  _alert_env_set "ALERT_TG_CHAT_ID"   "$2"
  log_success "已设置 Telegram"
}

alert_set_discord(){
  _alert_env_set "ALERT_DISCORD_WEBHOOK" "$1"
  log_success "已设置 Discord Webhook"
}

alert_set_wechat(){
  _alert_env_set "ALERT_PUSHPLUS_TOKEN" "$1"
  log_success "已设置 WeChat PushPlus"
}

alert_set_webhook(){
  local url="$1" fmt="${2:-raw}"
  _alert_env_set "ALERT_WEBHOOK"        "$url"
  _alert_env_set "ALERT_WEBHOOK_FORMAT" "$fmt"
  log_success "已设置通用 Webhook（${fmt}）"
}

alert_test(){
  ensure_alert_conf
  local budget_gib
  budget_gib=$(jq -r '.monthly_gib // 100' "$ALERT_PUB" 2>/dev/null)
  [[ "$budget_gib" =~ ^[0-9]+$ ]] || budget_gib=100
  local pct="${1:-40}"
  [[ "$pct" =~ ^[0-9]+$ && "$pct" -ge 0 && "$pct" -le 100 ]] || { log_error "百分比 0-100"; return 1; }
  local GiB=1073741824 mf="$TRAFFIC_DIR/logs/monthly.csv" m; m=$(date +%Y-%m)
  mkdir -p "$TRAFFIC_DIR/logs"
  [[ -s "$mf" ]] || echo "month,vps,resi,total,tx,rx" > "$mf"
  grep -q "^$m," "$mf" || echo "$m,0,0,0,0,0" >> "$mf"
  local used=$(( GiB * budget_gib * pct / 100 ))
  awk -F, -v m="$m" -v u="$used" 'BEGIN{OFS=","} NR==1{print;next} $1==m{$4=u} {print}' "$mf" > "$mf.tmp" && mv "$mf.tmp" "$mf"
  rm -f "$TRAFFIC_DIR/alert.state"
  if [[ -x "$SCRIPTS_DIR/traffic-alert.sh" ]]; then "$SCRIPTS_DIR/traffic-alert.sh"; else /etc/edgebox/scripts/traffic-alert.sh 2>/dev/null || true; fi
  echo -e "${CYAN}最近告警日志：${NC}"; tail -n 10 /var/log/edgebox-traffic-alert.log 2>/dev/null || true
  log_success "已模拟 ${pct}% 用量并触发预警（不产生真实流量）"
}

#############################################
# 备份恢复
#############################################

backup_create(){
    local ts=$(date +%Y%m%d_%H%M%S)
    local file="${BACKUP_DIR}/edgebox_backup_${ts}.tar.gz"
    mkdir -p "${BACKUP_DIR}"
    local t="/tmp/edgebox_backup_${ts}"
    mkdir -p "$t"

    # 备份主要配置
    cp -r /etc/edgebox "$t/" 2>/dev/null || true
    mkdir -p "$t/nginx"; cp /etc/nginx/nginx.conf "$t/nginx/" 2>/dev/null || true
    mkdir -p "$t/systemd"
    cp /etc/systemd/system/xray.service "$t/systemd/" 2>/dev/null || true
    cp /etc/systemd/system/sing-box.service "$t/systemd/" 2>/dev/null || true
    [[ -d /etc/letsencrypt ]] && cp -r /etc/letsencrypt "$t/" 2>/dev/null || true
    crontab -l > "$t/crontab.txt" 2>/dev/null || true

    # 备份Web文件
    mkdir -p "$t/www"; cp -r /var/www/html "$t/www/" 2>/dev/null || true

    # v4.6.0-rc4 (审核 P2#7): tar 失败必须 return 1（旧版本只 log_error 不 return, 让自动化无法判断）
    if tar -C "$t" -czf "$file" . 2>/dev/null && rm -rf "$t"; then
        log_success "备份完成: $file"
        # 清理旧备份，保留最近10个
        ls -t ${BACKUP_DIR}/edgebox_backup_*.tar.gz 2>/dev/null | tail -n +11 | xargs rm -f 2>/dev/null || true
        return 0
    else
        log_error "备份失败 (tar 命令未能创建有效归档)"
        rm -rf "$t" "$file" 2>/dev/null
        return 1
    fi
}

backup_list(){
    echo -e "${CYAN}备份列表：${NC}"
    ls -lh ${BACKUP_DIR}/edgebox_backup_*.tar.gz 2>/dev/null | awk '{print "  " $9 "  " $5 "  " $6 " " $7 " " $8}' || echo "  无备份文件"
}

backup_restore(){
    local f="$1"
    [[ -z "$f" || ! -f "$f" ]] && { echo "用法: edgeboxctl backup restore /path/to/edgebox_backup_xxx.tar.gz"; return 1; }
    log_info "恢复备份: $f"
    local restore_dir="/tmp/edgebox_restore_$$"
    mkdir -p "$restore_dir"

    if tar -xzf "$f" -C "$restore_dir" 2>/dev/null; then
        log_info "备份文件解压成功，开始验证..."

        # === BEGIN VALIDATION ===
        local valid_backup=true
        local xray_cfg_bak="${restore_dir}/etc/edgebox/config/xray.json"
        local sbox_cfg_bak="${restore_dir}/etc/edgebox/config/sing-box.json"
        local nginx_cfg_bak="${restore_dir}/nginx/nginx.conf"

        # Check Xray config
        if [[ -f "$xray_cfg_bak" ]]; then
            if ! jq empty "$xray_cfg_bak" >/dev/null 2>&1; then
                log_error "备份中的 xray.json 格式无效！"
                valid_backup=false
            else
                 log_info "备份中的 xray.json 格式有效。"
            fi
        else
            log_warn "备份中未找到 xray.json (可能不影响恢复，但请注意)"
            # Allow restore even if missing, user might be restoring partial backup
        fi

        # Check Sing-box config
        if [[ -f "$sbox_cfg_bak" ]]; then
            if ! jq empty "$sbox_cfg_bak" >/dev/null 2>&1; then
                log_error "备份中的 sing-box.json 格式无效！"
                valid_backup=false
            else
                log_info "备份中的 sing-box.json 格式有效。"
            fi
        else
            log_warn "备份中未找到 sing-box.json (可能不影响恢复，但请注意)"
        fi

        # Check Nginx config existence (basic check)
        if [[ ! -f "$nginx_cfg_bak" ]]; then
             log_warn "备份中未找到 nginx/nginx.conf"
        else
             log_info "备份中找到 nginx.conf。"
        fi
        # === END VALIDATION ===

        if [[ "$valid_backup" != "true" ]]; then
            log_error "备份文件验证失败，恢复操作已中止！关键配置文件格式无效。"
            rm -rf "$restore_dir"
            return 1
        fi

        log_info "备份文件验证通过，开始恢复..."

        # 恢复配置 (Use cp -a for permissions, ignore errors for non-critical parts)
        log_info "恢复 /etc/edgebox ..."
        [[ -d "$restore_dir/etc/edgebox" ]] && cp -a "$restore_dir/etc/edgebox/." /etc/edgebox/ 2>/dev/null || log_warn "未能恢复 /etc/edgebox"

        log_info "恢复 nginx.conf ..."
        [[ -f "$restore_dir/nginx/nginx.conf" ]] && cp -a "$restore_dir/nginx/nginx.conf" /etc/nginx/nginx.conf 2>/dev/null || log_warn "未能恢复 nginx.conf"

        log_info "恢复 systemd units ..."
        [[ -f "$restore_dir/systemd/xray.service" ]] && cp -a "$restore_dir/systemd/xray.service" /etc/systemd/system/ 2>/dev/null || true
        [[ -f "$restore_dir/systemd/sing-box.service" ]] && cp -a "$restore_dir/systemd/sing-box.service" /etc/systemd/system/ 2>/dev/null || true

        log_info "恢复 Let's Encrypt certificates (if present)..."
        [[ -d "$restore_dir/letsencrypt" ]] && cp -a "$restore_dir/letsencrypt/." /etc/letsencrypt/ 2>/dev/null || true

        log_info "恢复 Web 文件 ..."
        [[ -d "$restore_dir/www/html" ]] && cp -a "$restore_dir/www/html/." /var/www/html/ 2>/dev/null || true

        log_info "恢复 crontab ..."
        [[ -f "$restore_dir/crontab.txt" ]] && crontab "$restore_dir/crontab.txt" 2>/dev/null || true

        # 清理临时文件
        rm -rf "$restore_dir"
        log_success "文件恢复完成。"

        # 重载 systemd 并重启服务
        log_info "正在重载 systemd 并重启服务以应用恢复的配置..."
        systemctl daemon-reload
        if reload_or_restart_services nginx xray sing-box; then
             log_success "服务重启成功。"
        else
             log_error "部分服务重启失败，请手动检查: edgeboxctl status"
             return 1 # Indicate partial failure
        fi
        log_success "恢复操作成功完成！"

    else
        log_error "恢复失败：无法解压备份文件 '$f'"
        rm -rf "$restore_dir"
        return 1
    fi
}

#############################################
# 配置管理
#############################################

# 重新生成所有协议的UUID和密码
regenerate_uuid() {
    # v4.6.0-rc4 (审核 P1#3 致命): 完整重写 - 候选配置校验 + 安全权限 + 失败回滚
    # 旧版本问题: tmp+mv 后无 chmod 600；写后才校验；reload || true 吞失败；
    #            订阅重生失败仍报成功；force 参数字符串不匹配
    # 新版本流程:
    #   1. 生成新凭据
    #   2. 在临时目录构建候选 server.json / xray.json / sing-box.json
    #   3. xray -test 校验候选 xray.json
    #   4. sing-box check 校验候选 sing-box.json
    #   5. 原子替换正式文件 (install -m 600 root:root)
    #   6. reload xray / sing-box, 失败立即回滚旧配置
    #   7. 重生订阅, 失败也回滚
    #   8. 任一步失败: 完整恢复 + return 1

    # v4.6.0-rc4 (审核 P1#4): force 参数兼容 — 接受 "true" / "force" / 数字（hours，向后兼容旧调用）
    local force_arg="${1:-false}"
    local force=false
    case "$force_arg" in
        true|force|--force|--immediate)     force=true ;;
        [0-9]*)                              force=true ;;  # 数字 = 老 sub_revoke 调用习惯
        *)                                   force=false ;;
    esac

    if [[ "$force" != "true" && "${EDGEBOX_FORCE:-0}" != "1" && "${EDGEBOX_FORCE:-0}" != "yes" ]]; then
        echo -e "${YELLOW}警告：此操作将重新生成所有协议凭据，所有现有客户端将断开连接。${NC}"
        if [[ ! -t 0 ]]; then
            log_error "非交互模式下需要 force 参数或 EDGEBOX_FORCE=1"
            return 1
        fi
        read -p "确认继续？(yes/no): " confirm
        [[ "$confirm" != "yes" ]] && { log_info "已取消"; return 0; }
    fi

    log_info "重新生成 v4.0.0 协议凭据..."

    local server_json="${CONFIG_DIR}/server.json"
    local xray_json="${CONFIG_DIR}/xray.json"
    local sb_json="${CONFIG_DIR}/sing-box.json"

    [[ -f "$server_json" ]] || { log_error "server.json 不存在"; return 1; }

    # 备份当前配置（失败时整体回滚用）
    local ts; ts=$(date +%Y%m%d_%H%M%S)
    local bak_dir="/tmp/edgebox-regen-uuid-${ts}"
    mkdir -p "$bak_dir"
    chmod 700 "$bak_dir"
    cp -p "$server_json" "$bak_dir/" 2>/dev/null || true
    [[ -f "$xray_json"  ]] && cp -p "$xray_json"  "$bak_dir/" 2>/dev/null
    [[ -f "$sb_json"    ]] && cp -p "$sb_json"    "$bak_dir/" 2>/dev/null
    log_info "  备份当前配置: $bak_dir"

    # 定义回滚函数
    _regen_rollback() {
        log_warn "  回滚到 $bak_dir ..."
        [[ -f "$bak_dir/server.json"   ]] && install -o root -g root -m 600 "$bak_dir/server.json"   "$server_json"  2>/dev/null
        [[ -f "$bak_dir/xray.json"     ]] && install -o root -g root -m 600 "$bak_dir/xray.json"     "$xray_json"    2>/dev/null
        [[ -f "$bak_dir/sing-box.json" ]] && install -o root -g root -m 600 "$bak_dir/sing-box.json" "$sb_json"      2>/dev/null
        systemctl reload xray 2>/dev/null || systemctl restart xray 2>/dev/null || log_error "  xray 服务无法恢复 — 手动检查"
        systemctl reload sing-box 2>/dev/null || systemctl restart sing-box 2>/dev/null || log_error "  sing-box 服务无法恢复 — 手动检查"
        log_warn "  回滚完成 (旧凭据已恢复)"
    }

    # 生成新凭据
    local NEW_UUID_VLESS_REALITY NEW_PASSWORD_HYSTERIA2
    NEW_UUID_VLESS_REALITY=$(uuidgen)
    NEW_PASSWORD_HYSTERIA2=$(openssl rand -base64 32 | tr -d '\n')

    if [[ -z "$NEW_UUID_VLESS_REALITY" || -z "$NEW_PASSWORD_HYSTERIA2" ]]; then
        log_error "凭据生成失败 (uuidgen/openssl 不可用?)"
        return 1
    fi

    # umask 077 保证所有 mktemp 出来的临时文件权限是 600
    local _old_umask; _old_umask=$(umask); umask 077

    # 1) 构建候选 server.json
    local server_tmp; server_tmp=$(mktemp /tmp/edgebox-server.XXXXXX) || { log_error "mktemp 失败"; umask "$_old_umask"; return 1; }
    if ! jq --arg ur "$NEW_UUID_VLESS_REALITY" \
            --arg ph "$NEW_PASSWORD_HYSTERIA2" \
            '.uuid.vless.reality = $ur
           | .password.hysteria2 = $ph
           | .updated_at = (now | todate)' "$server_json" > "$server_tmp"; then
        log_error "更新 server.json 失败 (jq)"
        rm -f "$server_tmp"
        umask "$_old_umask"
        return 1
    fi

    # 2) 构建候选 xray.json
    local xray_tmp=""
    if [[ -f "$xray_json" ]]; then
        xray_tmp=$(mktemp /tmp/edgebox-xray.XXXXXX) || { log_error "mktemp 失败"; rm -f "$server_tmp"; umask "$_old_umask"; return 1; }
        if ! jq --arg ur "$NEW_UUID_VLESS_REALITY" '
                (.inbounds[] | select(.tag=="vless-reality") | .settings.clients[0].id) = $ur
            ' "$xray_json" > "$xray_tmp"; then
            log_error "更新 xray.json 失败 (jq)"
            rm -f "$server_tmp" "$xray_tmp"
            umask "$_old_umask"
            return 1
        fi
        # 候选 xray.json 必须通过 xray -test
        if ! /usr/local/bin/xray -test -format json -c "$xray_tmp" >/dev/null 2>&1; then
            log_error "候选 xray.json 校验失败 — 取消变更"
            /usr/local/bin/xray -test -format json -c "$xray_tmp" 2>&1 | tail -10 >&2
            rm -f "$server_tmp" "$xray_tmp"
            umask "$_old_umask"
            return 1
        fi
    fi

    # 3) 构建候选 sing-box.json
    local sb_tmp=""
    if [[ -f "$sb_json" ]]; then
        sb_tmp=$(mktemp /tmp/edgebox-sb.XXXXXX) || { log_error "mktemp 失败"; rm -f "$server_tmp" "$xray_tmp"; umask "$_old_umask"; return 1; }
        if ! jq --arg ph "$NEW_PASSWORD_HYSTERIA2" '
                (.inbounds[] | select(.type=="hysteria2") | .users[0].password) = $ph
            ' "$sb_json" > "$sb_tmp"; then
            log_error "更新 sing-box.json 失败 (jq)"
            rm -f "$server_tmp" "$xray_tmp" "$sb_tmp"
            umask "$_old_umask"
            return 1
        fi
        # 候选 sing-box.json 必须通过 sing-box check（如果可用）
        if command -v sing-box >/dev/null 2>&1; then
            if ! sing-box check -c "$sb_tmp" >/dev/null 2>&1; then
                log_error "候选 sing-box.json 校验失败 — 取消变更"
                sing-box check -c "$sb_tmp" 2>&1 | tail -10 >&2
                rm -f "$server_tmp" "$xray_tmp" "$sb_tmp"
                umask "$_old_umask"
                return 1
            fi
        fi
    fi

    # 4) 候选全部通过，原子替换正式文件（保证权限 600 root:root）
    log_info "  候选配置全部校验通过，正在应用..."
    if ! install -o root -g root -m 600 "$server_tmp" "$server_json"; then
        log_error "替换 server.json 失败"
        rm -f "$server_tmp" "$xray_tmp" "$sb_tmp"
        umask "$_old_umask"
        return 1
    fi
    rm -f "$server_tmp"

    if [[ -n "$xray_tmp" ]]; then
        if ! install -o root -g root -m 600 "$xray_tmp" "$xray_json"; then
            log_error "替换 xray.json 失败 — 回滚"
            _regen_rollback
            rm -f "$xray_tmp" "$sb_tmp"
            umask "$_old_umask"
            return 1
        fi
        rm -f "$xray_tmp"
    fi

    if [[ -n "$sb_tmp" ]]; then
        if ! install -o root -g root -m 600 "$sb_tmp" "$sb_json"; then
            log_error "替换 sing-box.json 失败 — 回滚"
            _regen_rollback
            rm -f "$sb_tmp"
            umask "$_old_umask"
            return 1
        fi
        rm -f "$sb_tmp"
    fi

    umask "$_old_umask"

    # 5) 严格 reload 服务（失败回滚）
    log_info "  重载 xray..."
    if ! systemctl reload xray >/dev/null 2>&1 && ! systemctl restart xray >/dev/null 2>&1; then
        log_error "xray 重载失败 — 回滚"
        systemctl status xray --no-pager -l 2>&1 | tail -10 >&2
        _regen_rollback
        return 1
    fi

    log_info "  重载 sing-box..."
    if ! systemctl reload sing-box >/dev/null 2>&1 && ! systemctl restart sing-box >/dev/null 2>&1; then
        log_error "sing-box 重载失败 — 回滚"
        systemctl status sing-box --no-pager -l 2>&1 | tail -10 >&2
        _regen_rollback
        return 1
    fi

    # 6) 重生订阅
    export UUID_VLESS_REALITY="$NEW_UUID_VLESS_REALITY"
    export PASSWORD_HYSTERIA2="$NEW_PASSWORD_HYSTERIA2"

    if ! eb_gen_subscription; then
        log_error "订阅重生失败 — 配置已更新但订阅文件没刷新，请手动 edgeboxctl restart 后重试"
        # 不回滚：UUID 已写入服务，回滚配置反而会让客户端配置和服务凭据不一致
        return 1
    fi

    log_success "凭据已更新；订阅文件已刷新"
    echo -e "  ${YELLOW}VLESS-Reality UUID:${NC}  ${GREEN}$NEW_UUID_VLESS_REALITY${NC}"
    echo -e "  ${YELLOW}Hysteria2 密码:${NC}      ${GREEN}$NEW_PASSWORD_HYSTERIA2${NC}"
    echo -e "  ${YELLOW}备份保留在:${NC}        $bak_dir"
    echo -e "  ${YELLOW}如确认无需回滚, 可删除:${NC}  rm -rf $bak_dir"
    return 0
}


show_config(){
    echo -e "${CYAN}EdgeBox 配置信息：${NC}"
    if [[ -f ${CONFIG_DIR}/server.json ]]; then
        local server_ip=$(jq -r '.server_ip' ${CONFIG_DIR}/server.json)
        local version=$(jq -r '.version' ${CONFIG_DIR}/server.json)
        local install_date=$(jq -r '.install_date' ${CONFIG_DIR}/server.json)

        echo -e "  版本: ${YELLOW}v${version}${NC}"
        echo -e "  服务器IP: ${YELLOW}${server_ip}${NC}"
        echo -e "  安装日期: ${YELLOW}${install_date}${NC}"
        echo -e "  证书模式: ${YELLOW}$(get_current_cert_mode)${NC}"

        echo -e "\n${CYAN}协议配置：${NC}"
        echo -e "  VLESS-Reality UUID: $(jq -r '.uuid.vless.reality // "(missing)"' ${CONFIG_DIR}/server.json)"
        echo -e "  Hysteria2 密码:     $(jq -r '.password.hysteria2 // "(missing)"' ${CONFIG_DIR}/server.json)"
        echo -e "  Reality 公钥:       $(jq -r '.reality.public_key // "(missing)"' ${CONFIG_DIR}/server.json)"
        echo -e "  Reality SNI:        $(get_current_sni_domain || echo '(unknown)')"
    else
        echo -e "${RED}配置文件不存在${NC}"
    fi
}


#############################################
# Reality密钥轮换 (Bulletproof & Self-Contained)
#############################################

# 辅助函数：检查是否需要轮换
check_reality_rotation_needed() {
    # <<< FIX: Define all required variables LOCALLY to be fully self-contained >>>
    local CONFIG_DIR="/etc/edgebox/config"
    local REALITY_ROTATION_STATE="${CONFIG_DIR}/reality-rotation.json"
    local REALITY_ROTATION_DAYS=60

    local force_rotation=${1:-false}
    [[ "$force_rotation" == "true" ]] && return 0

    if [[ ! -f "$REALITY_ROTATION_STATE" ]]; then
        log_info "首次运行，创建轮换状态文件..."
        mkdir -p "$(dirname "$REALITY_ROTATION_STATE")" # Ensure directory exists

        # <<< FIX: Read current public key from server.json on first run >>>
        local current_pubkey
        current_pubkey=$(jq -r '.reality.public_key // ""' "${CONFIG_DIR}/server.json" 2>/dev/null)

        local next_rotation
        next_rotation=$(date -d "+${REALITY_ROTATION_DAYS} days" -Iseconds)

        # Write all three fields to the initial state file
        jq -n \
          --arg next_rotation "$next_rotation" \
          --arg last_rotation "$(date -Iseconds)" \
          --arg pubkey "$current_pubkey" \
          '{next_rotation: $next_rotation, last_rotation: $last_rotation, last_public_key: $pubkey}' > "$REALITY_ROTATION_STATE"

        log_info "下次轮换将在: $next_rotation"
        return 1
    fi

    local next_rotation_time
    next_rotation_time=$(jq -r '.next_rotation' "$REALITY_ROTATION_STATE" 2>/dev/null)

    if [[ -n "$next_rotation_time" && "$next_rotation_time" != "null" ]]; then
        local next_timestamp
        next_timestamp=$(date -d "$next_rotation_time" +%s 2>/dev/null || echo 0)
        local current_timestamp
        current_timestamp=$(date +%s)

        if [[ $current_timestamp -ge $next_timestamp ]]; then
            log_info "Reality密钥已到轮换时间。"
            return 0
        else
            return 1
        fi
    fi

    return 1 # Default to no rotation needed
}

# 辅助函数：更新Xray配置
update_xray_reality_keys() {
    # v4.6.0-rc4 (审核 P1#8): 候选 xray.json 写正式前必须 xray -test 校验
    # 旧版本: jq | mv 后才 reload xray, 没校验 → 坏配置直接上线
    local new_private_key="$1"
    local new_short_id="$2"
    local CONFIG_DIR="/etc/edgebox/config"
    local XRAY_CONFIG="${CONFIG_DIR}/xray.json"
    local temp_config; temp_config=$(mktemp /tmp/xray.rotate-keys.XXXXXX) || { log_error "mktemp 失败"; return 1; }

    if ! jq --arg private_key "$new_private_key" \
       --arg short_id "$new_short_id" \
       '(.inbounds[]? | select(.tag? | test("reality"; "i")) | .streamSettings.realitySettings.privateKey) = $private_key |
        (.inbounds[]? | select(.tag? | test("reality"; "i")) | .streamSettings.realitySettings.shortIds) = [$short_id]' \
       "${XRAY_CONFIG}" > "$temp_config"; then
        log_error "  jq 更新 xray.json 失败"
        rm -f "$temp_config"
        return 1
    fi

    # 候选 xray.json 必须通过 -test
    if ! /usr/local/bin/xray -test -format json -c "$temp_config" >/dev/null 2>&1; then
        log_error "  候选 xray.json 校验失败"
        /usr/local/bin/xray -test -format json -c "$temp_config" 2>&1 | tail -10 >&2
        rm -f "$temp_config"
        return 1
    fi

    # 原子替换 + 强制 600 root:root
    if ! install -o root -g root -m 600 "$temp_config" "${XRAY_CONFIG}"; then
        log_error "  install xray.json 失败"
        rm -f "$temp_config"
        return 1
    fi
    rm -f "$temp_config"
    return 0
}

# 辅助函数：更新server.json
update_server_reality_keys() {
    # v4.6.0-rc4 (审核 P1#8): 跟 xray 一样 — 检查 jq 返回值, 强制 600 root:root
    local new_private_key="$1"
    local new_public_key="$2"
    local new_short_id="$3"
    local CONFIG_DIR="/etc/edgebox/config"
    local temp_server; temp_server=$(mktemp /tmp/server.rotate-keys.XXXXXX) || return 1

    if ! jq --arg private_key "$new_private_key" \
       --arg public_key "$new_public_key" \
       --arg short_id "$new_short_id" \
       '.reality.private_key = $private_key |
        .reality.public_key = $public_key |
        .reality.short_id = $short_id' \
       "${CONFIG_DIR}/server.json" > "$temp_server"; then
        log_error "  jq 更新 server.json 失败"
        rm -f "$temp_server"
        return 1
    fi

    if ! install -o root -g root -m 600 "$temp_server" "${CONFIG_DIR}/server.json"; then
        log_error "  install server.json 失败"
        rm -f "$temp_server"
        return 1
    fi
    rm -f "$temp_server"
    return 0
}

# 辅助函数：更新轮换状态文件
update_reality_rotation_state() {
    local new_public_key="$1"
    local CONFIG_DIR="/etc/edgebox/config" # Self-contained
    local REALITY_ROTATION_STATE="${CONFIG_DIR}/reality-rotation.json"
    local REALITY_ROTATION_DAYS=60

    local current_time
    current_time=$(date -Iseconds)
    local next_rotation
    next_rotation=$(date -d "+${REALITY_ROTATION_DAYS} days" -Iseconds)

    echo "{\"last_rotation\":\"$current_time\",\"next_rotation\":\"$next_rotation\",\"last_public_key\":\"$new_public_key\"}" > "$REALITY_ROTATION_STATE"
}

# 主函数：执行密钥轮换 (已修正并包含所有依赖和即时面板刷新)
rotate_reality_keys() {
    local force_rotation=${1:-false}
    log_info "开始Reality密钥轮换流程..."

    if ! check_reality_rotation_needed "$force_rotation"; then
        log_info "当前不需要轮换Reality密钥。"
        return 0
    fi

    log_info "正在备份当前配置..."
    local ts; ts=$(date +%Y%m%d_%H%M%S)
    local xray_backup="${CONFIG_DIR}/xray_backup_${ts}.json"
    local server_backup="${CONFIG_DIR}/server_backup_${ts}.json"
    if ! cp -p "${XRAY_CONFIG}" "$xray_backup"; then
        log_error "备份 xray.json 失败"; return 1
    fi
    if ! cp -p "${CONFIG_DIR}/server.json" "$server_backup"; then
        log_error "备份 server.json 失败"; rm -f "$xray_backup"; return 1
    fi
    chmod 600 "$xray_backup" "$server_backup"

    log_info "正在生成新的密钥对..."
    local reality_output
    reality_output=$(sing-box generate reality-keypair 2>/dev/null) || { log_error "sing-box命令执行失败"; return 1; }

    local new_private_key new_public_key new_short_id
    new_private_key="$(echo "$reality_output" | grep -oP 'PrivateKey: \K[a-zA-Z0-9_-]+')"
    new_public_key="$(echo "$reality_output" | grep -oP 'PublicKey: \K[a-zA-Z0-9_-]+')"
    new_short_id="$(openssl rand -hex 4)"

    if [[ -z "$new_private_key" || -z "$new_public_key" ]]; then
        log_error "新密钥生成失败，已中止轮换。"
        return 1
    fi
    log_success "新密钥生成成功。"

    # v4.6.0-rc4 (审核 P1#8): 严格检查 update_*_reality_keys 返回码
    # 这俩函数现在内部 xray -test 校验 + 强制 600 root:root 权限 + 返回真实 rc
    # 旧版本: 直接调用不检查返回值, 若 xray.json 写出坏 JSON, 后续 reload 才发现
    if ! update_xray_reality_keys "$new_private_key" "$new_short_id"; then
        log_error "更新 xray.json 失败 — 配置未被修改, 无需回滚"
        rm -f "$xray_backup" "$server_backup"
        return 1
    fi

    if ! update_server_reality_keys "$new_private_key" "$new_public_key" "$new_short_id"; then
        log_error "更新 server.json 失败 — 回滚 xray.json"
        install -o root -g root -m 600 "$xray_backup" "${XRAY_CONFIG}" 2>/dev/null
        rm -f "$xray_backup" "$server_backup"
        return 1
    fi

    log_info "正在重载Xray服务..."
    if ! reload_or_restart_services xray; then
        log_error "Xray服务重载失败！正在从备份恢复..."
        install -o root -g root -m 600 "$xray_backup"   "${XRAY_CONFIG}"           2>/dev/null
        install -o root -g root -m 600 "$server_backup" "${CONFIG_DIR}/server.json" 2>/dev/null
        reload_or_restart_services xray
        rm -f "$xray_backup" "$server_backup"
        return 1
    fi
    log_success "Xray服务已应用新密钥。"

    log_info "正在刷新订阅链接..."
    local mode
    mode=$(get_current_cert_mode 2>/dev/null || echo self-signed)
    if [[ "$mode" == "self-signed" ]]; then
      if ! regen_sub_ip; then
          log_error "订阅刷新失败 — 凭据已更新但订阅文件没刷新"
          rm -f "$xray_backup" "$server_backup"
          return 1
      fi
    else
      local d="${mode##*:}"
      if [[ -n "$d" ]]; then
          if ! regen_sub_domain "$d"; then
              log_error "域名订阅刷新失败"
              rm -f "$xray_backup" "$server_backup"
              return 1
          fi
      else
          regen_sub_ip || { log_error "订阅刷新失败"; rm -f "$xray_backup" "$server_backup"; return 1; }
      fi
    fi

    update_reality_rotation_state "$new_public_key"

    log_info "正在刷新Web面板数据..."
    if [[ -x "${SCRIPTS_DIR}/dashboard-backend.sh" ]]; then
        bash "${SCRIPTS_DIR}/dashboard-backend.sh" --now >/dev/null 2>&1 || log_warn "Dashboard data refresh failed, will update on next cron run."
        log_success "Web面板数据已刷新。"
    else
        log_warn "dashboard-backend.sh not found, panel will update on next cron run."
    fi

    log_success "Reality密钥轮换成功！"
    echo -e "  ${YELLOW}重要: 请通知用户更新订阅以获取新配置。${NC}"
    echo -e "  新公钥 (pbk): ${GREEN}${new_public_key}${NC}"
    echo -e "  新短ID (sid): ${GREEN}${new_short_id}${NC}"
    echo -e "  备份在 ${xray_backup} / ${server_backup}"
    return 0
}

# === Reality 无感 SID 轮换（追加新 SID，24h 后自动清理旧 SID）===
rotate_reality_sid_graceful() {
  # 配置路径（按你的项目习惯可改）
  local XRAY_CONFIG="${XRAY_CONFIG:-/etc/edgebox/config/xray.json}"
  local grace_hours="${EB_SID_GRACE_HOURS:-24}"

  # 读取"当前第一个旧 SID"
  local old_sid
  old_sid="$(jq -r '.inbounds[]?|select(.tag=="vless-reality")|.streamSettings.realitySettings.shortIds[0] // empty' "$XRAY_CONFIG")"

  # v4.6.0-rc4 (审核 P1#8): 候选 xray.json 写入正式前必须通过 xray -test
  # 旧版本: jq | mv 后才 reload, 坏 JSON 会让 xray 直接挂
  # 新版本: mktemp + 校验 + install -m 600
  local tmp; tmp=$(mktemp /tmp/xray.rotate-sid.XXXXXX) || { echo "[ERR] mktemp 失败" >&2; return 1; }

  # 生成并【追加】新 SID（去重）
  local new_sid; new_sid="$(openssl rand -hex 4)"
  if ! jq --arg sid "$new_sid" '
    .inbounds |= map(
      if .tag=="vless-reality" then
        .streamSettings.realitySettings.shortIds =
          (((.streamSettings.realitySettings.shortIds // []) + [$sid]) | unique)
      else . end
    )' "$XRAY_CONFIG" > "$tmp"; then
      echo "[ERR] jq 写入新 SID 失败" >&2
      rm -f "$tmp"
      return 1
  fi

  # 候选 xray.json 必须 xray -test 通过
  if ! /usr/local/bin/xray -test -format json -c "$tmp" >/dev/null 2>&1; then
      echo "[ERR] 候选 xray.json 校验失败" >&2
      /usr/local/bin/xray -test -format json -c "$tmp" 2>&1 | tail -10 >&2
      rm -f "$tmp"
      return 1
  fi

  # 原子替换 + 强制 600 root:root
  if ! install -o root -g root -m 600 "$tmp" "$XRAY_CONFIG"; then
      echo "[ERR] install xray.json 失败" >&2
      rm -f "$tmp"
      return 1
  fi
  rm -f "$tmp"

  # 重载 xray (失败则回滚 - 这种回滚只能依赖外部备份, 这里至少返回非零)
  if ! systemctl reload xray 2>/dev/null && ! systemctl restart xray 2>/dev/null; then
      echo "[ERR] xray 重载失败 — 配置已落盘但服务可能未生效" >&2
      systemctl status xray --no-pager -l 2>&1 | tail -10 >&2
      return 1
  fi
  echo "[OK] Reality 新 SID 已生效：$new_sid   （将宽限 ${grace_hours}h）"

  # ==================== 新增修复代码 START ====================

  # 1. 更新 server.json，将新的 SID 设为主要 SID
  local server_json_tmp; server_json_tmp=$(mktemp /tmp/server.rotate-sid.XXXXXX) || server_json_tmp="${CONFIG_DIR}/server.json.tmp"
  if jq --arg sid "$new_sid" '.reality.short_id = $sid' "${CONFIG_DIR}/server.json" > "$server_json_tmp"; then
      if install -o root -g root -m 600 "$server_json_tmp" "${CONFIG_DIR}/server.json"; then
          echo "[INFO] 前端数据源 server.json 已同步为新 SID"
      else
          echo "[WARN] install server.json 失败" >&2
      fi
      rm -f "$server_json_tmp"
  else
      rm -f "$server_json_tmp"
      echo "[WARN] 更新 server.json 失败" >&2
  fi

  # 2. 重新生成订阅文件，确保新下载的订阅包含新的 SID
  log_info "正在刷新订阅链接以包含新的 SID..."
  local mode; mode="$(get_current_cert_mode 2>/dev/null || echo self-signed)"
  if [[ "$mode" == "self-signed" ]]; then
    regen_sub_ip || log_warn "订阅刷新失败"
  else
    local domain="${mode##*:}"
    [[ -n "$domain" ]] && { regen_sub_domain "$domain" || log_warn "域名订阅刷新失败"; } || regen_sub_ip
  fi

  # 3. 立即触发一次 dashboard-backend.sh 刷新，使面板马上更新
  if [[ -x "/etc/edgebox/scripts/dashboard-backend.sh" ]]; then
      echo "[INFO] 正在立即刷新控制面板数据..."
      /etc/edgebox/scripts/dashboard-backend.sh --now >/dev/null 2>&1 || echo "[WARN] 面板刷新失败，将在5分钟内由定时任务自动更新" >&2
  fi

  # ===================== 新增修复代码 END =====================

  # 24h 后用 systemd-run 清理旧 SID
  if [[ -n "$old_sid" ]]; then
    # v4.6.0-rc4 (审核 P1#7): 真实实现 — 旧版本只有注释占位，旧 SID 永不删除
    # 新版本: 用 systemd-run 排定一次性 oneshot 任务，到时后从 xray.json 删除旧 SID
    # 安全: 用 umask 077 + install -m 600 保护 xray.json (审核 P1#3 同样问题)
    # 持久: --on-active 配合 --timer-property=Persistent=true，重启后仍会触发
    local cleanup_filter='
      .inbounds |= map(
        if .tag=="vless-reality" then
          .streamSettings.realitySettings.shortIds |=
            ((. // []) | map(select(. != $old and . != "")))
        else . end
      )'
    local b64; b64="$(printf "%s" "$cleanup_filter" | (base64 -w0 2>/dev/null || base64))"
    local payload
    payload="umask 077; cfg='${XRAY_CONFIG}'; tmp=\$(mktemp /tmp/xray.sid-grace.XXXXXX); \
b64='$b64'; filter=\$(echo \"\$b64\" | base64 -d); \
jq --arg old '$old_sid' \"\$filter\" \"\$cfg\" > \"\$tmp\" \
&& /usr/local/bin/xray -test -format json -c \"\$tmp\" \
&& install -o root -g root -m 600 \"\$tmp\" \"\$cfg\" \
&& (systemctl reload xray 2>/dev/null || systemctl restart xray 2>/dev/null) >/dev/null 2>&1; \
rm -f \"\$tmp\" 2>/dev/null"

    if command -v systemd-run >/dev/null 2>&1; then
        if systemd-run \
              --unit="edgebox-sid-cleanup-${old_sid:0:6}-$(date +%s)" \
              --on-active="${grace_hours}h" \
              --timer-property=Persistent=true \
              --property=Type=oneshot \
              /bin/bash -lc "$payload" >/dev/null 2>&1; then
            echo "[INFO] 已安排 ${grace_hours}h 后清理旧 SID：$old_sid（systemd-run 持久定时器）"
        else
            echo "[WARN] systemd-run 创建定时器失败；请手动 ${grace_hours}h 后执行：" >&2
            echo "[WARN]   /bin/bash -lc \"$payload\"" >&2
        fi
    else
        echo "[WARN] systemd-run 不可用：旧 SID ($old_sid) 不会自动清理；" >&2
        echo "[WARN] 旧 SID 会在下次 rotate-sid 调用时自动覆盖；如需立即清理，可手动执行：" >&2
        echo "[WARN]   jq '(.inbounds[] | select(.tag==\"vless-reality\") | .streamSettings.realitySettings.shortIds) |= map(select(. != \"$old_sid\"))' /etc/edgebox/config/xray.json > /tmp/xr.json && mv /tmp/xr.json /etc/edgebox/config/xray.json && systemctl reload xray" >&2
    fi
  else
    echo "[INFO] 没有检测到旧 SID；这次无需安排清理任务。"
  fi
}

# 主函数：显示轮换状态
show_reality_rotation_status() {
    log_info "查看Reality密钥轮换状态..."
    local CONFIG_DIR="/etc/edgebox/config" # Self-contained
    local REALITY_ROTATION_STATE="${CONFIG_DIR}/reality-rotation.json"

    if [[ ! -f "$REALITY_ROTATION_STATE" ]]; then
        # Call the check function which will create the file on first run
        check_reality_rotation_needed "false" >/dev/null 2>&1
    fi

    if [[ ! -f "$REALITY_ROTATION_STATE" ]]; then
        log_error "无法读取或创建Reality轮换状态文件。"
        return 1
    fi

    local next_rotation last_rotation pubkey
    next_rotation=$(jq -r '.next_rotation' "$REALITY_ROTATION_STATE")
    last_rotation=$(jq -r '.last_rotation' "$REALITY_ROTATION_STATE")
    pubkey=$(jq -r '.last_public_key // "N/A"' "$REALITY_ROTATION_STATE")

    echo "=== Reality密钥轮换状态 ==="
    echo "  上次轮换: ${last_rotation}"
    echo "  下次轮换: ${next_rotation}"
    echo "  当前公钥: ${pubkey:0:20}..."

    local next_ts current_ts days_rem
    next_ts=$(date -d "$next_rotation" +%s 2>/dev/null || echo 0)
    current_ts=$(date +%s)
    days_rem=$(( (next_ts - current_ts) / 86400 ))

    if [[ "$next_ts" -eq 0 ]]; then
        echo "  状态: 日期格式无效"
    elif [[ "$days_rem" -gt 0 ]]; then
        echo "  剩余时间: ${days_rem} 天"
    else
        echo "  状态: ${RED}已到期或过期，建议立即轮换！${NC}"
    fi

    echo ""
    echo "  注意: Reality 协议密钥不会因时间被破解，'到期'仅是建议性的。"
    echo "  如需手动轮换: edgeboxctl rotate-reality --confirm"
    echo "  (该操作会让所有现有客户端订阅失效)"
}


#############################################
# SNI域名管理
#############################################

# --- SNI域名管理 (这是调用部分，逻辑不变，但现在调用的是内部函数) ---
sni_pool_list() {
    if [[ ! -f "$SNI_DOMAINS_CONFIG" ]]; then
        log_error "SNI配置文件不存在: $SNI_DOMAINS_CONFIG"
        return 1
    fi
    echo "SNI域名池状态:"
    echo "$(printf "%-25s %-8s %-12s %-15s %-20s" "域名" "权重" "成功率" "响应时间" "最后检查")"
    echo "$(printf "%s" "$(printf "%-25s %-8s %-12s %-15s %-20s" | tr " " "-")")"

    if ! jq -r '.domains[] | [.hostname, .weight, (.success_rate // 0), (.avg_response_time // 0), (.last_check // "未检查")] | @tsv' "$SNI_DOMAINS_CONFIG" 2>/dev/null; then
        echo "配置文件格式错误或jq命令不可用"
        return 1
    fi | while IFS=$'\t' read -r hostname weight success_rate response_time last_check; do
        printf "%-25s %-8s %-12s %-15s %-20s\n" \
            "$hostname" "$weight" "${success_rate}" "${response_time}s" "$last_check"
    done

    echo ""
    echo "当前使用: $(get_current_sni_domain || echo "未配置")"
}

sni_test_all() {
    health_check_domains
}

sni_auto_select() {
    auto_select_optimal_domain
}

sni_set_domain() {
    local target_domain="$1"

    if [[ -z "$target_domain" ]]; then
        echo "用法: edgeboxctl sni set <域名>"
        return 1
    fi
    target_domain=${target_domain#*//}

    # v4.6.0-rc4 (审核 P2#5 followup): SNI 域名必须是真实可解析的域名
    # 旧版本: 直接信任输入, 用户可以设 "invalid.invalid" 让 Reality 全部失效但 CLI 仍报成功
    # 新版本: 三层校验
    #   1) 域名语法格式（防止 nginx map 注入）
    #   2) DNS 解析（必须有 A/AAAA 记录）
    #   3) 端口 443 可达（必须真有 HTTPS 服务）
    if declare -f eb_is_valid_domain >/dev/null 2>&1; then
        if ! eb_is_valid_domain "$target_domain"; then
            log_error "SNI 域名格式无效: $target_domain"
            log_error "  必须是有效域名 (例如 www.microsoft.com)"
            return 1
        fi
    fi

    # DNS 解析检查
    if ! getent hosts "$target_domain" >/dev/null 2>&1; then
        log_error "SNI 域名无法解析: $target_domain"
        log_error "  Reality 需要真实可达的伪装站点。"
        log_error "  推荐: www.microsoft.com / www.apple.com / www.cloudflare.com"
        return 1
    fi

    # 端口 443 可达检查（5 秒超时）
    if ! timeout 5 bash -c "</dev/tcp/$target_domain/443" 2>/dev/null; then
        log_warn "SNI 域名 $target_domain 在端口 443 上不可达"
        log_warn "  Reality 客户端将无法用此域名做伪装。如确认要继续，加 --force"
        if [[ "${2:-}" != "--force" ]]; then
            return 1
        fi
    fi

    log_info "手动设置SNI域名: $target_domain"

    if update_sni_domain "$target_domain"; then
        log_success "SNI域名设置成功: $target_domain"
        return 0
    else
        log_error "SNI域名设置失败。"
        return 1
    fi
}

# v4.6.0-rc4 (hotfix): wrap upgrade body in function so `return 1` is legal bash
# Previously: return inside case branch (not in function) → bash error → case parsing broke,
#             help case code 'leaked' through, causing print_cmd: command not found errors
_eb_do_upgrade() {
    log_info "EdgeBox 升级流程 (保留凭据)..."

    # 1. 检查前置：必须以 root 运行
    if [[ "$EUID" -ne 0 ]]; then
        log_error "升级需要 root 权限。请用: sudo edgeboxctl upgrade"
        return 1
    fi

    # 2. 检查 server.json 存在
    if [[ ! -f "${CONFIG_DIR}/server.json" ]]; then
        log_error "未发现 ${CONFIG_DIR}/server.json — 无凭据可保留"
        log_error "如果是首次安装，请直接运行 bootstrap.sh"
        return 1
    fi

    # 3. 创建完整备份
    local ts backup_file
    ts=$(date +%Y%m%d-%H%M%S)
    backup_file="/root/edgebox-backup/upgrade-${ts}.tar.gz"
    mkdir -p /root/edgebox-backup
    log_info "创建备份: $backup_file"
    if ! tar czf "$backup_file" \
        /etc/edgebox \
        /usr/local/bin/edgeboxctl \
        /etc/cron.d/edgebox-* 2>/dev/null; then
        log_warn "tar 备份返回非零（可能某些文件不存在），但 server.json/scripts 应已含入"
    fi
    log_success "备份完成 ($(du -h "$backup_file" | awk '{print $1}'))"

    # 4. 保留 server.json 到 /tmp，让新 install.sh 检测后复用凭据
    local keep_file="/tmp/edgebox-keep-server.json"
    cp -p "${CONFIG_DIR}/server.json" "$keep_file"
    chmod 600 "$keep_file"
    log_info "凭据已保留: $keep_file"

    # v4.6.0-rc4 (审核 升级保留): 同时保留其他关键状态
    # 这些文件不会进 install.sh 重新生成路径，所以必须 stash 起来并在 install 完后还原
    local keep_dir="/tmp/edgebox-keep-state"
    rm -rf "$keep_dir"
    mkdir -p "$keep_dir/config" "$keep_dir/cert"
    chmod 700 "$keep_dir"

    # cert_mode 文件（letsencrypt:<domain> 或 self-signed）
    [[ -f "${CONFIG_DIR}/cert_mode" ]] && cp -p "${CONFIG_DIR}/cert_mode" "$keep_dir/config/"

    # alert.env （Webhook/Token 等告警凭据）
    [[ -f "${CONFIG_DIR}/alert.env" ]] && cp -p "${CONFIG_DIR}/alert.env" "$keep_dir/config/"

    # shunt/ 目录（出站分流配置）
    [[ -d "${CONFIG_DIR}/shunt" ]] && cp -rp "${CONFIG_DIR}/shunt" "$keep_dir/config/"

    # current.* 证书符号链接和 Let's Encrypt 链接的目标 (cert 目录里)
    [[ -d /etc/edgebox/cert ]] && cp -rp /etc/edgebox/cert/. "$keep_dir/cert/" 2>/dev/null || true

    log_info "扩展状态已保留: $keep_dir (cert_mode/alert.env/shunt/cert)"

    # 5. 设置升级标记，让 bootstrap/install.sh 知道是升级（不退出非交互检查）
    export EDGEBOX_UPGRADE=1

    # 6. 调用 bootstrap.sh 走 SHA256 校验路径
    log_info "调用 bootstrap.sh 重新安装 (走 SHA256 校验)..."
    if ! curl -fsSL https://raw.githubusercontent.com/cuiping89/node/main/ENV/bootstrap.sh | EDGEBOX_UPGRADE=1 bash; then
        log_error "============================================"
        log_error "升级失败！"
        log_error "============================================"
        log_error "备份位置: $backup_file"
        log_error ""
        log_error "手动恢复步骤:"
        log_error "  1. cd /"
        log_error "  2. tar xzf $backup_file"
        log_error "  3. systemctl restart nginx xray sing-box"
        log_error ""
        log_error "保留文件可用于重试: $keep_file  + $keep_dir"
        return 1
    fi

    # v4.6.0-rc4 (审核 P1#9): install 完成后还原扩展状态 + 重新应用运行拓扑
    # 旧版本: 升级域名节点后 install 强制走 IP-mode 拓扑，跟 server.json 不一致
    # 新版本: 还原配置文件后，按 cert_mode 状态重新应用拓扑
    if [[ -d "$keep_dir" ]]; then
        log_info "还原扩展状态..."
        if [[ -f "$keep_dir/config/cert_mode" ]]; then
            install -o root -g root -m 644 "$keep_dir/config/cert_mode" "${CONFIG_DIR}/cert_mode"
            log_info "  ✓ cert_mode 已还原"
        fi
        if [[ -f "$keep_dir/config/alert.env" ]]; then
            install -o root -g root -m 600 "$keep_dir/config/alert.env" "${CONFIG_DIR}/alert.env"
            log_info "  ✓ alert.env 已还原 (告警 Token 保留)"
        fi
        if [[ -d "$keep_dir/config/shunt" ]]; then
            mkdir -p "${CONFIG_DIR}/shunt"
            cp -rp "$keep_dir/config/shunt/." "${CONFIG_DIR}/shunt/"
            chown -R root:root "${CONFIG_DIR}/shunt"
            log_info "  ✓ shunt/ 已还原 (出站分流配置)"
        fi

        # v4.7.0: 从 keep 文件读取升级前的证书拓扑状态 (CDN 已移除)
        local was_cert_mode="self-signed" was_cert_domain=""
        if [[ -f "$keep_file" ]]; then
            was_cert_mode=$(jq -r '.cert.mode // "self-signed"' "$keep_file" 2>/dev/null)
            was_cert_domain=$(jq -r '.cert.domain // ""'      "$keep_file" 2>/dev/null)
        fi

        # v4.6.0-rc4 (审核 P1#7): 拓扑恢复失败必须传播 — 不再 "log_warn + 继续报成功"
        # 用 _topology_rc 标记任一关键步失败, 决定最终成败
        local _topology_rc=0

        # 拓扑分支1: 域名模式 (LE 证书)
        if [[ "$was_cert_mode" == "letsencrypt" && -n "$was_cert_domain" && "$was_cert_domain" != "null" ]]; then
            log_info "  检测到升级前为域名模式 (domain=$was_cert_domain)，重新应用域名拓扑..."
            if [[ -d /etc/letsencrypt/live/${was_cert_domain} ]]; then
                ln -sfnT "/etc/letsencrypt/live/${was_cert_domain}/fullchain.pem" /etc/edgebox/cert/current.pem
                ln -sfnT "/etc/letsencrypt/live/${was_cert_domain}/privkey.pem"   /etc/edgebox/cert/current.key
                log_info "    ✓ Let's Encrypt 证书链接已还原"

                if ! generate_nginx_stream_map_conf "domain" "$was_cert_domain"; then
                    log_error "    ✗ stream map 切换失败"
                    _topology_rc=1
                fi

                # 同步 server.json.cert
                local _sj="${CONFIG_DIR}/server.json"
                local _tmp="${_sj}.tmp"
                if jq --arg d "$was_cert_domain" \
                     '.cert.mode = "letsencrypt" | .cert.domain = $d | .cert.auto_renew = true' \
                     "$_sj" > "$_tmp" 2>/dev/null; then
                    install -o root -g root -m 600 "$_tmp" "$_sj" || _topology_rc=1
                    rm -f "$_tmp"
                fi

                if declare -f regen_sub_domain >/dev/null 2>&1; then
                    if ! regen_sub_domain "$was_cert_domain"; then
                        log_error "    ✗ 域名订阅重生失败"
                        _topology_rc=1
                    fi
                fi
                if ! reload_or_restart_services nginx xray sing-box; then
                    log_error "    ✗ 服务重载失败"
                    _topology_rc=1
                fi
                if [[ "$_topology_rc" -eq 0 ]]; then
                    log_info "  ✓ 域名拓扑已重新应用"
                fi
            else
                log_error "  ✗ /etc/letsencrypt/live/${was_cert_domain} 不存在，无法还原域名模式"
                log_error "    将保留 IP 模式拓扑。手动恢复: edgeboxctl switch-to-domain $was_cert_domain"
                _topology_rc=1
            fi

        else
            # 拓扑分支2: IP 模式 — install 默认行为已经正确，无需额外操作
            log_info "  IP 模式: install 默认拓扑已正确，无需调整"
        fi

        # 清理保留目录
        rm -rf "$keep_dir"
    fi

    # 7. 清理 keep 文件 + 总结
    rm -f "$keep_file"

    # v4.6.0-rc4 (审核 P1#7): 根据 _topology_rc 决定是否真的"成功"
    # v4.6.0-rc4 (hotfix 退出码): 直接 return 真实退出码。
    #   旧实现在失败分支里写 `_eb_dispatch_rc=1; false`, 却在 if 之后无条件
    #   `return 0` —— return 0 同时覆盖了 false 的 $? 和全局 _eb_dispatch_rc,
    #   导致拓扑恢复失败时脚本仍 exit 0, 与 P1#7 "退出码可信" 的目标相悖。
    if [[ "${_topology_rc:-0}" -ne 0 ]]; then
        log_error "============================================"
        log_error "  ❌ 升级完成但拓扑恢复失败"
        log_error "============================================"
        log_error "  凭据已保留, 但运行拓扑跟升级前不一致"
        log_error "  备份保留在: $backup_file"
        log_error "  上面的错误日志给出了手动恢复命令"
        return 1
    else
        log_success "============================================"
        log_success "  ✅ 升级成功"
        log_success "============================================"
        log_info "  凭据未变更（订阅 URL、UUID、密码等都保持原值）"
        log_info "  备份保留在: $backup_file"
        log_info "  如不需要可删除: rm -f $backup_file"
        return 0
    fi
}

# v4.6.0-rc4 (审核 P1#1): 证书续期封装为函数。
#   旧实现把续期逻辑直接写在顶层 case 分支里并使用 `local`，而 `local` 只能在函数内使用——
#   在顶层会报 "local: can only be used in a function"，且 `local exit_code=$?` 赋值失败，
#   导致 certbot 的真实失败码被丢弃、失败被误报为成功 (cert renew 返回 0)。
#   封装进函数后 local 合法、退出码可信。
cert_renew() {
    local renew_output exit_code
    log_info "尝试续期 Let's Encrypt 证书..."

    # 移除 --quiet 以捕获输出，并确保在无代理环境下执行
    renew_output=$(env -u ALL_PROXY -u HTTP_PROXY -u HTTPS_PROXY -u http_proxy -u https_proxy certbot renew 2>&1)
    exit_code=$?

    echo -e "\n${CYAN}--- Certbot 续期日志 ---${NC}"
    echo "$renew_output" | sed 's/^/  /g'
    echo -e "${CYAN}--------------------------${NC}\n"

    if [[ "$exit_code" -ne 0 ]]; then
        log_error "证书续期失败 (certbot 退出码 ${exit_code})！请检查上面的 Certbot 日志。"
        echo ""
        cert_status
        return "$exit_code"
    fi

    if echo "$renew_output" | grep -q -E "Congratulations, all renewals succeeded|Successfully received certificate"; then
        log_success "证书续期成功！"
        log_info "正在重载相关服务以应用新证书..."
        if ! reload_or_restart_services nginx xray sing-box; then
            log_error "新证书已签发但服务重载失败，请检查 nginx -t / xray -test / sing-box check"
            echo ""
            cert_status
            return 1
        fi
    elif echo "$renew_output" | grep -q "Cert not yet due for renewal"; then
        log_success "证书尚未到达续期时间，无需操作。"
    else
        log_warn "Certbot 命令执行成功，但未检测到明确的续期成功信息。"
    fi

    echo ""
    cert_status
    return 0
}

#############################################
# 主命令处理
#############################################

# v4.6.0-rc4 (审核 P1#2 致命): 配置加载必须发生在 case 之前
# 旧版本: 配置加载在 case ... esac 之后, 会让脚本退出码 = load_config_once 的退出码 (通常 0)
#         即使 case 分支里的函数 return 1, 脚本仍 exit 0, 自动化无法判断成败
# 新版本: 1) 先加载配置 2) 跑 case 3) 用 $? 记录 case 退出码 4) 显式 exit "$rc"
if [[ "${BASH_SOURCE[0]}" == "${0}" ]] || [[ -n "${EDGEBOXCTL_LOADED}" ]]; then
    [[ "${EDGEBOX_DEBUG}" == "true" ]] && LOG_LEVEL="debug"

    # v4.7.0 (前端报错 #1): 早期分流 — help/version/--help/-h 不需要 root，也不需要配置加载。
    # 旧逻辑会无条件 load_config_once，非 root 用户读不到 600 root:root 的 server.json
    # → 显示 "配置文件JSON格式错误或解析失败"，把帮助命令也搞成报错。
    case "${1:-help}" in
        help|--help|-h|version|--version|-v|"")
            : # 让后续 case 分支正常处理；不做配置加载，不做 root 检查
            ;;
        *)
            # v4.7.0: 自动 sudo 提权（与 bootstrap.sh 一致）。
            # server.json 是 600 root:root（保护 UUID/密码/dashboard cookie 等敏感数据），
            # 普通用户读不到 → jq 失败。改为：检测到非 root 就 exec sudo 自我重新执行，
            # 不再让用户每次都手敲 sudo。
            if [[ "$EUID" -ne 0 ]]; then
                if command -v sudo >/dev/null 2>&1; then
                    # -E 保留 EDGEBOX_DEBUG / LOG_LEVEL 等环境变量；-- 防止 $1 被 sudo 误解析为选项
                    exec sudo -E -- "$0" "$@"
                else
                    echo -e "${RED}[ERROR]${NC} edgeboxctl 需要 root 权限运行，但 sudo 不可用" >&2
                    echo -e "${YELLOW}原因：${NC}/etc/edgebox/config/server.json 是 600 root:root，保护敏感配置" >&2
                    exit 1
                fi
            fi
            mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null
            load_config_once 2>/dev/null || true   # 配置加载失败不阻断（部分子命令不需要配置）
            log_debug "edgeboxctl初始化完成，配置已缓存"
            ;;
    esac
fi

# v4.6.0-rc4 (审核 P1#2): 跟踪 case 分支真实退出码
_eb_dispatch_rc=0

case "$1" in
  # 基础功能
  status) show_status ;;
  restart) restart_services ;;
  logs|log) show_logs "$2" ;;
  test) test_connection ;;
  debug-ports) debug_ports ;;

    sub|subscription)
    ensure_sub_dirs >/dev/null 2>&1 || true
    case "$2" in
      issue)   shift 2; sub_issue "$1" "${2:-}";;
      show)    shift 2; sub_show "$1";;
      revoke)  shift 2; sub_revoke "$@";;
      limit)   shift 2; sub_limit "$1" "$2";;
      ""|list) show_sub ;;   # 兼容：不带参数仍显示整份订阅（管理员/自用）
*) echo "用法:
edgeboxctl sub                         # 显示并刷新全局订阅链接 (/sub-<token>)
edgeboxctl sub issue  <user> [limit]   # 为用户下发专属订阅链接 (/share/u-...)
edgeboxctl sub show   <user>           # 查看专属订阅与已登记设备
edgeboxctl sub revoke <user>           # 停用用户的专属订阅
edgeboxctl sub limit  <user> <N>       # 调整用户的设备上限"
exit 2
;;
    esac
    ;;

  # 备注服务器名称
   "alias")
        if [[ -n "$2" ]]; then
            set_user_alias "$2"
        else
            echo "用法: edgeboxctl alias \"备注内容\""
            echo "当前备注: $(jq -r '.user_alias // "未设置"' /etc/edgebox/config/server.json 2>/dev/null || echo "未设置")"
        fi
        ;;

  # 证书管理
cert)
    case "$2" in
      status|"")
        cert_status
        ;;
      renew)
        cert_renew
        ;;
      *)
        echo "用法: edgeboxctl cert [status|renew]"
        exit 2
        ;;
    esac
    ;;
	
  fix-permissions) fix_permissions ;;
  cert-status) cert_status ;;                 # 兼容旧命令

  switch-to-domain)
    shift
    switch_to_domain "$1"
    ;;
  switch-to-ip)
    switch_to_ip
    ;;

  # 配置管理
  config)
    case "$2" in
      show) show_config ;;
      regenerate-uuid) regenerate_uuid ;;
      *) echo "用法: edgeboxctl config [show|regenerate-uuid]"; exit 2 ;;
    esac
    ;;

  # 出站分流
  shunt)
    case "$2" in
      vps) setup_outbound_vps ;;
      resi) setup_outbound_resi "$3" ;;
      direct-resi) setup_outbound_direct_resi "$3" ;;
      status) show_shunt_status ;;
      whitelist) shift 2; manage_whitelist "$@" ;;
      *) echo "用法: edgeboxctl shunt [vps|resi|direct-resi|status|whitelist] [args...]"; exit 2 ;;
    esac
    ;;

  # 预警配置
    alert)
    ensure_alert_conf
    case "$2" in
      show|"")        alert_show ;;
      monthly)        shift 2; alert_set_monthly "$1" ;;
      steps)          shift 2; alert_set_steps "$1" ;;
      telegram)       shift 2; alert_set_telegram "$1" "$2" ;;
      discord)        shift 2; alert_set_discord "$1" ;;
      wechat)         shift 2; alert_set_wechat "$1" ;;
      webhook)        shift 2; alert_set_webhook "$1" "${2:-raw}" ;;
      test)           shift 2; alert_test "${1:-40}" ;;
      # v4.1.0: 静默与状态控制（通过 lib/alert.sh）
      silence)
        shift 2
        _hrs="${1:-1}"
        if [[ -f "${SCRIPTS_DIR}/lib/alert.sh" ]]; then
          # shellcheck source=/dev/null
          source "${SCRIPTS_DIR}/lib/alert.sh"
          eb_alert_silence "$_hrs"
          echo "告警已静默 ${_hrs} 小时（仅本地日志，不发外部渠道）"
        else
          echo "ERROR: lib/alert.sh not installed"; exit 1
        fi
        ;;
      unsilence)
        if [[ -f "${SCRIPTS_DIR}/lib/alert.sh" ]]; then
          source "${SCRIPTS_DIR}/lib/alert.sh"
          eb_alert_unsilence
          echo "告警已恢复"
        else
          echo "ERROR: lib/alert.sh not installed"; exit 1
        fi
        ;;
      status)
        if [[ -f "${SCRIPTS_DIR}/lib/alert.sh" ]]; then
          source "${SCRIPTS_DIR}/lib/alert.sh"
          if eb_alert_is_silenced; then
            _ts=$(cat /etc/edgebox/traffic/alert.silenced_until 2>/dev/null)
            echo "告警状态: SILENCED until $(date -d "@$_ts" 2>/dev/null || echo "$_ts")"
          else
            echo "告警状态: ACTIVE"
          fi
          echo ""
          echo "已配置的渠道:"
          # v4.6.0-rc4 (审核 P1#7): source alert.sh 不会解析 alert.env（只有 eb_alert_send
          #   内部才解析），故这些 env 变量在此处恒为空。改用与 alert_show 一致的 grep 检测。
          _has_value() { grep -qE "^${1}=[\"']?[^\"' ]" "$ALERT_ENV" 2>/dev/null; }
          _has_value ALERT_TG_BOT_TOKEN && _has_value ALERT_TG_CHAT_ID && echo "  - Telegram"
          _has_value ALERT_DISCORD_WEBHOOK && echo "  - Discord"
          _has_value ALERT_PUSHPLUS_TOKEN  && echo "  - PushPlus (微信)"
          if _has_value ALERT_WEBHOOK; then
            _wf=$(grep -E '^ALERT_WEBHOOK_FORMAT=' "$ALERT_ENV" 2>/dev/null | cut -d= -f2- | tr -d '"'"'"' ')
            echo "  - Webhook (${_wf:-raw})"
          fi
          _has_value ALERT_EMAIL           && echo "  - Email"
          echo ""
          echo "最近告警 (查看 /var/log/edgebox/alerts.log):"
          tail -20 /var/log/edgebox/alerts.log 2>/dev/null || echo "  (暂无)"
        fi
        ;;
      *) echo "用法: edgeboxctl alert [show|monthly <GiB>|steps <p1,p2,..>|telegram <token> <chat>|discord <url>|wechat <pushplus_token>|webhook <url> [raw|slack|discord]|test <percent>|silence <hours>|unsilence|status]"; exit 2 ;;
    esac
    ;;

  # v4.1.0: 协议健康监控
  monitor)
    case "${2:-status}" in
      status)
        _hf=/etc/edgebox/traffic/protocol-health.json
        if [[ -f "$_hf" ]]; then
          _mode=$(jq -r '.mode // "unknown"' "$_hf")
          _total=$(jq -r '.metrics.total // 0' "$_hf")
          _healthy=$(jq -r '.metrics.healthy // 0' "$_hf")
          _down=$(jq -r '.metrics.down // 0' "$_hf")
          _unverified=$(jq -r '.metrics.listening_unverified // 0' "$_hf")
          _updated=$(jq -r '.generated_at // "unknown"' "$_hf")
          echo "============================================"
          echo " 协议健康监控状态"
          echo "============================================"
          echo " 模式: $_mode"
          echo " 上次检查: $_updated"
          echo " 概览: $_healthy 健康 / $_unverified 待验证 / $_down 故障 (共 $_total 个协议)"
          echo "============================================"
          jq -r '.protocols[] | "  [\(.state | ascii_upcase)] \(.name) - \(.details)"' "$_hf"
          echo "============================================"
        else
          echo "暂无健康报告。手动运行: edgeboxctl monitor test"
        fi
        ;;
      mode)
        _newmode="$3"
        case "$_newmode" in
          monitor|repair|off)
            mkdir -p /etc/edgebox/traffic
            echo "$_newmode" > /etc/edgebox/traffic/health_mode
            echo "健康监控模式已设置为: $_newmode"
            echo ""
            case "$_newmode" in
              monitor) echo "(默认 - 仅检测+告警，永不自动重启服务)";;
              repair)  echo "⚠️  (检测到故障时会自动重启服务，但不修改配置/防火墙)";;
              off)     echo "(完全关闭健康检查)";;
            esac
            ;;
          ""|"--help"|"-h")
            _cur=$(cat /etc/edgebox/traffic/health_mode 2>/dev/null || echo "monitor")
            echo "当前模式: $_cur"
            echo ""
            echo "用法: edgeboxctl monitor mode <monitor|repair|off>"
            echo ""
            echo "  monitor (默认) - 只检测+告警，不动任何服务和配置"
            echo "  repair        - 检测到 down 时尝试重启对应服务（不改配置）"
            echo "  off           - 完全关闭健康检查"
            ;;
          *)
            echo "ERROR: 无效模式 '$_newmode'"
            echo "可选: monitor | repair | off"
            exit 1
            ;;
        esac
        ;;
      test)
        _mode=$(cat /etc/edgebox/traffic/health_mode 2>/dev/null || echo "monitor")
        echo "手动执行健康检查 (mode=$_mode)..."
        HEALTH_MODE="$_mode" "${SCRIPTS_DIR}/protocol-health-monitor.sh"
        echo ""
        echo "结果已写入 /etc/edgebox/traffic/protocol-health.json"
        echo "运行 'edgeboxctl monitor status' 查看摘要"
        ;;
      log|logs)
        tail -50 /var/log/edgebox/health-monitor.log 2>/dev/null || echo "暂无日志"
        ;;
      *)
        echo "用法: edgeboxctl monitor [status|mode <monitor|repair|off>|test|logs]"
        echo ""
        echo "  status (默认) - 显示协议健康状态摘要"
        echo "  mode <模式>   - 设置或查看健康监控模式"
        echo "  test          - 立即执行一次健康检查"
        echo "  logs          - 查看最近 50 行健康监控日志"
        ;;
    esac
    ;;

  # v4.2.0: cron 任务管理
  cron)
    _cron_default=/etc/cron.d/edgebox-default
    _cron_optin=/etc/cron.d/edgebox-optin

    # opt-in 任务白名单（name -> cron line）
    _cron_optin_def() {
        case "$1" in
            sni-auto)
                echo "0 3 * * 0 root /usr/bin/flock -n /var/lock/edgebox_sni.lock /usr/local/bin/edgeboxctl sni auto >> /var/log/edgebox/sni-auto.log 2>&1"
                ;;
            rotate-sid)
                echo "15 3 1,15 * * root /usr/bin/flock -n /var/lock/edgebox_maint.lock /usr/bin/env EB_SID_GRACE_HOURS=168 /usr/local/bin/edgeboxctl rotate-sid >> /var/log/edgebox/rotate-sid.log 2>&1"
                ;;
            traffic-randomize-light)
                echo "0 4 * * * root /etc/edgebox/scripts/edgebox-traffic-randomize.sh light >/dev/null 2>&1"
                ;;
            traffic-randomize-medium)
                echo "0 5 * * 0 root /etc/edgebox/scripts/edgebox-traffic-randomize.sh medium >/dev/null 2>&1"
                ;;
            traffic-randomize-heavy)
                echo "0 6 1 * * root /etc/edgebox/scripts/edgebox-traffic-randomize.sh heavy >/dev/null 2>&1"
                ;;
            *) return 1 ;;
        esac
        return 0
    }

    _cron_optin_desc() {
        case "$1" in
            sni-auto)                  echo "每周日 03:00 自动选优 SNI 域名" ;;
            rotate-sid)                echo "每月 1/15 日 03:15 轮换 Reality shortId（7天宽限期）" ;;
            traffic-randomize-light)   echo "每天 04:00 轻度随机化 Hysteria2 伪装" ;;
            traffic-randomize-medium)  echo "每周日 05:00 中度随机化（影响更多参数）" ;;
            traffic-randomize-heavy)   echo "每月 1 日 06:00 重度随机化（影响最多参数）" ;;
            *) echo "(unknown)" ;;
        esac
    }

    _cron_optin_all="sni-auto rotate-sid traffic-randomize-light traffic-randomize-medium traffic-randomize-heavy"

    _is_optin_enabled() {
        local name="$1"
        [[ -f "$_cron_optin" ]] || return 1
        # Look for the marker line "# EDGEBOX-OPTIN: <name>"
        grep -qE "^# EDGEBOX-OPTIN: ${name}\$" "$_cron_optin" 2>/dev/null
    }

    case "${2:-list}" in
      list|status)
        echo "============================================"
        echo " EdgeBox Cron 任务清单"
        echo "============================================"
        echo ""
        echo "🟢 默认启用 (自动安装，安全只读类):"
        if [[ -f "$_cron_default" ]]; then
            grep -E "^[*0-9]" "$_cron_default" 2>/dev/null | while IFS= read -r line; do
                echo "    ✓ $line"
            done
        else
            echo "    (默认 cron 文件不存在: $_cron_default)"
        fi
        echo ""
        echo "⚪ 可选任务 (opt-in，需要时手动启用):"
        for name in $_cron_optin_all; do
            if _is_optin_enabled "$name"; then
                printf "    ✓ %-28s %s\n" "$name" "$(_cron_optin_desc "$name")"
            else
                printf "    ○ %-28s %s\n" "$name" "$(_cron_optin_desc "$name")"
            fi
        done
        echo ""
        echo "🔴 永远不允许的 cron 任务:"
        echo "    × rotate-reality              重新生成 Reality 密钥（会让所有客户端失效）"
        echo ""
        echo "用法:"
        echo "    edgeboxctl cron enable  <name>   - 启用某个可选任务"
        echo "    edgeboxctl cron disable <name>   - 停用某个可选任务"
        echo "============================================"
        ;;
      enable)
        _name="${3:-}"
        if [[ -z "$_name" ]]; then
            echo "用法: edgeboxctl cron enable <name>"
            echo "可选: $_cron_optin_all"
            exit 1
        fi
        # 拒绝 rotate-reality
        if [[ "$_name" == "rotate-reality" ]]; then
            echo "❌ 拒绝: rotate-reality 永远不允许通过 cron 自动执行"
            echo "   原因: 轮换 Reality 密钥会让所有客户端的订阅失效"
            echo "   如需手动轮换: edgeboxctl rotate-reality --confirm"
            exit 1
        fi
        _line=$(_cron_optin_def "$_name") || {
            echo "❌ 未知任务: $_name"
            echo "可选: $_cron_optin_all"
            exit 1
        }
        # 已经启用？
        if _is_optin_enabled "$_name"; then
            echo "ℹ️  $_name 已经是启用状态"
            exit 0
        fi
        # 写入 opt-in 文件
        mkdir -p /etc/cron.d
        [[ -f "$_cron_optin" ]] || cat > "$_cron_optin" <<'HEAD'
# EdgeBox v4.2.0 - opt-in cron
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
HEAD
        echo "" >> "$_cron_optin"
        echo "# EDGEBOX-OPTIN: $_name" >> "$_cron_optin"
        echo "# $(_cron_optin_desc "$_name")" >> "$_cron_optin"
        echo "$_line" >> "$_cron_optin"
        chmod 0644 "$_cron_optin"
        systemctl reload cron 2>/dev/null || systemctl restart cron 2>/dev/null || \
            service cron reload 2>/dev/null || service cron restart 2>/dev/null || true
        echo "✅ 已启用: $_name"
        echo "   $(_cron_optin_desc "$_name")"
        ;;
      disable)
        _name="${3:-}"
        if [[ -z "$_name" ]]; then
            echo "用法: edgeboxctl cron disable <name>"
            exit 1
        fi
        if [[ ! -f "$_cron_optin" ]]; then
            echo "ℹ️  没有任何 opt-in cron 任务"
            exit 0
        fi
        if ! _is_optin_enabled "$_name"; then
            echo "ℹ️  $_name 当前未启用"
            exit 0
        fi
        # 删除三行：marker、desc 注释、实际 cron 行
        _tmp=$(mktemp)
        awk -v n="$_name" '
            /^# EDGEBOX-OPTIN: / {
                if ($0 == "# EDGEBOX-OPTIN: " n) {
                    skip = 3
                    next
                }
            }
            skip > 0 { skip--; next }
            { print }
        ' "$_cron_optin" > "$_tmp"
        mv -f "$_tmp" "$_cron_optin"
        chmod 0644 "$_cron_optin"
        systemctl reload cron 2>/dev/null || systemctl restart cron 2>/dev/null || \
            service cron reload 2>/dev/null || service cron restart 2>/dev/null || true
        echo "✅ 已停用: $_name"
        ;;
      *)
        echo "用法: edgeboxctl cron [list|enable <name>|disable <name>]"
        echo ""
        echo "  list            - 显示所有任务及启用状态（默认）"
        echo "  enable <name>   - 启用某个可选任务"
        echo "  disable <name>  - 停用某个可选任务"
        ;;
    esac
    ;;

  # 备份恢复
  backup)
    case "$2" in
      create) backup_create ;;
      list) backup_list ;;
      restore) backup_restore "$3" ;;
      *) echo "用法: edgeboxctl backup [create|list|restore <file>]"; exit 2 ;;
    esac
    ;;

  # v4.6.0-rc4-rc1: 升级系统（保留凭据，简单版）
  # 流程: 1) 备份 -> 2) 保留 server.json -> 3) 调用 bootstrap.sh 重装
  #       4) install.sh 检测 keep 文件后跳过 generate_credentials
  #       5) 失败不自动回滚，提示用户手动恢复
  update|upgrade)
    # v4.6.0-rc4 (hotfix): delegate to function so `return 1` works inside it
    _eb_do_upgrade
    # v4.6.0-rc4 (hotfix 自覆盖竞态): 在已解析的 case 体内直接退出。
    #   升级会重装 /usr/local/bin/edgeboxctl 本身, 文件内容随之改变。
    #   若回落到 esac 之后的 `_eb_dispatch_rc=$?; exit`, 运行中的 bash 需要再次
    #   从磁盘读取脚本尾部 —— 而此时该 inode 的内容已被换成新版本, 按旧偏移读取
    #   会落在错位处, 报 "syntax error near unexpected token \`;;'"。
    #   整个 case 在执行前已解析进内存, 故此处 exit 不再触发磁盘回读, 竞态规避。
    #   (install.sh 的 _install_script 已改为原子 mv, 这里是第二道防线。)
    exit $?
    ;;

# Reality 密钥轮换
  # v4.3.0: rotate-reality 必须显式 --confirm 才能执行
  # 这是不可逆操作：所有现有客户端订阅会立即失效。
  rotate-reality)
    _have_confirm=0
    _have_force=0
    # 解析所有 flag（顺序无关）
    for arg in "$@"; do
        case "$arg" in
            --confirm) _have_confirm=1 ;;
            --force)   _have_force=1 ;;
        esac
    done

    if [[ "$_have_confirm" != "1" && "$_have_force" != "1" ]]; then
        # 既没 --confirm 也没 --force：拒绝并提示
        echo "==========================================================="
        echo "  ⚠️  rotate-reality 是不可逆操作"
        echo "==========================================================="
        echo ""
        echo "  此操作会重新生成 Reality 公私钥对和 shortId，"
        echo "  所有现有客户端的订阅 (pbk/sid) 将立即失效。"
        echo "  客户端必须重新导入订阅链接才能恢复使用。"
        echo ""
        echo "  通常你不需要主动运行此命令 —— Reality 协议本身没有"
        echo "  '密钥到期'的概念，密钥不会因时间被破解。"
        echo ""
        echo "  如确认要轮换，请运行："
        echo "    edgeboxctl rotate-reality --confirm"
        echo ""
        echo "  如要强制轮换（即使脚本判断不需要）："
        echo "    edgeboxctl rotate-reality --confirm --force"
        echo ""
        echo "==========================================================="
        exit 1
    fi

    if [[ "$_have_force" == "1" && "$_have_confirm" != "1" ]]; then
        # 向后兼容：v3 用户可能脚本里写了 --force 不带 --confirm
        echo "⚠️  WARNING: 检测到 --force 但未带 --confirm"
        echo "    v4.3.0 推荐用法: rotate-reality --confirm --force"
        echo "    (本次因向后兼容仍会执行，5 秒后开始...)"
        sleep 5
    fi

    if [[ "$_have_force" == "1" ]]; then
        rotate_reality_keys "true"
    else
        rotate_reality_keys "false"
    fi
    ;;

  reality-status)
    show_reality_rotation_status
    ;;

  rotate-sid)
    # v4.3.0: 默认优雅期从 24h 延长到 7d (168h)
    # 用法：edgeboxctl rotate-sid   (可选：EB_SID_GRACE_HOURS=24 edgeboxctl rotate-sid)
    : "${EB_SID_GRACE_HOURS:=168}"
    export EB_SID_GRACE_HOURS
    rotate_reality_sid_graceful
    ;;
	
   # SNI域名池管理
  sni)
    case "$2" in
      list|pool)
        sni_pool_list
        ;;
      test|test-all)
        sni_test_all
        ;;
      select|auto)
        sni_auto_select
        ;;
      set)
        sni_set_domain "$3"
        ;;
      *)
        echo "用法: edgeboxctl sni {list|test-all|auto|set <域名>}"
        exit 1
        ;;
    esac
    ;;

  # 流量管理 (统计 + 流量特征随机化)
  traffic)
    case "${2:-}" in
      # 流量统计
      "show"|"")
        traffic_show
        ;;
      # 流量特征随机化
      "randomize")
        traffic_randomize "${3:-light}"
        ;;
      "status")
        traffic_status
        ;;
      "reset")
        traffic_reset
        ;;
      *)
        echo "用法: edgeboxctl traffic [show|randomize|status|reset]"
        echo ""
        echo "流量统计:"
        echo "  show        - 显示流量使用统计"
        echo ""
        echo "流量特征随机化:"
        echo "  randomize   - 执行协议参数随机化 [light|medium|heavy]"
        echo "  status      - 显示随机化系统状态"
        echo "  reset       - 重置协议参数为默认值"
        exit 1
        ;;
    esac
    ;;

	test-udp)
    # 用法: edgeboxctl test-udp <host> <port> [seconds]
    host="${2:-127.0.0.1}" port="${3:-443}" secs="${4:-3}"
    echo "[INFO] UDP 简测: ${host}:${port}, ${secs}s"
    if command -v iperf3 >/dev/null 2>&1; then
      iperf3 -u -c "$host" -p "$port" -t "$secs" --bitrate 5M --get-server-output || true
    else
      echo "[WARN] 未安装 iperf3，退化为本地探测..."
      if command -v socat >/dev/null 2>&1; then
        printf 'x' | socat -T1 - udp:${host}:${port} && echo "[OK] 发送成功(不代表服务握手成功)"
      else
        echo "[HINT] 建议安装: apt-get install -y iperf3 socat"
      fi
    fi
    ;;

# 控制面板密码管理
dashboard)
    case "$2" in
      passcode)
        shift 2
        update_dashboard_passcode "$@"
        ;;
      *)
        echo "用法: edgeboxctl dashboard passcode [新密码]"
        echo "  - 不提供密码则提示输入，留空则随机生成 12 位"
        echo "  - 密码须为 6-64 位字母或数字（不含空格或符号）"
        ;;
    esac
    ;;

help|--help|-h|version|--version|-v|"")
  # --- 工具：带 ANSI 颜色时也能精确对齐注释列 ---
  strip_ansi() { sed -r 's/\x1B\[[0-9;]*m//g' <<<"$1"; }
  # $1=左侧文本(含颜色)  $2=注释文本  $3=注释列起始列(每板块独立)
  print_cmd() {
    local left="$1" comment="$2" col="${3:-60}"
    local plain="$(strip_ansi "$left")"
    local len=${#plain}
    local pad=$(( col - 2 - len ))   # 最左侧保持两格缩进
    (( pad < 1 )) && pad=1
    printf "  %b%*s${DIM}# %s${NC}\n" "$left" "$pad" "" "$comment"
  }

  # 每个板块的注释列（# 起始列），仅影响注释对齐，不改变你原有缩进层级
  _W_CORE=48
  _W_CERT=52
  _W_SNI=50
  _W_REALITY=48
  _W_TRAND=54
  _W_SUB=56
  _W_SHUNT=56
  _W_ALERT=56
  _W_CONF=56
  _W_DEBUG=52

  # 头部框线
  printf "%b\n" "${CYAN}════════════════════════════════════════════════════════════════"
  printf "  EdgeBox 管理工具 v%s\n" "${VERSION}"
  printf "%b\n\n" "════════════════════════════════════════════════════════════════${NC}"

  # 🎯 核心命令
  printf "%b\n" "${YELLOW}■ 🎯 核心命令${NC}"
  print_cmd "${GREEN}edgeboxctl sub${NC}"                           "查看订阅链接与 控制面板URL"                 $_W_CORE
  print_cmd "${GREEN}edgeboxctl status${NC}"                        "查看所有服务及端口的健康状态"               $_W_CORE
  print_cmd "${GREEN}edgeboxctl logs${NC} ${CYAN}<service>${NC}"    "查看指定服务的实时日志 (Ctrl+C 退出)"         $_W_CORE
  print_cmd "${GREEN}edgeboxctl restart${NC}"                       "优雅重启所有核心服务 (配置变更后使用)"        $_W_CORE
  print_cmd "${GREEN}edgeboxctl update${NC}"                        "在线更新 EdgeBox 至最新版本"                  $_W_CORE
  print_cmd "${GREEN}edgeboxctl help${NC}"                          "显示帮助信息"                              $_W_CORE
  printf "  %b\n" "${CYAN}示例:${NC}"
  printf "  %b %b\n\n" "${GREEN}edgeboxctl logs${NC}" "${CYAN}xray${NC}"

  # 🔒 证书切换
  printf "%b\n" "${YELLOW}■ 🔒 证书切换${NC}"
  print_cmd "${GREEN}edgeboxctl cert status${NC}"                             "查看当前证书类型、域名及有效期"            $_W_CERT
  print_cmd "${GREEN}edgeboxctl switch-to-domain${NC} ${CYAN}<domain>${NC}"  "切换为域名并申请 Let's Encrypt 证书"  $_W_CERT
  print_cmd "${GREEN}edgeboxctl cert renew${NC}"                              "手动续期 Let's Encrypt 证书"               $_W_CERT
  print_cmd "${GREEN}edgeboxctl switch-to-ip${NC}"                            "切换回 IP 模式，使用自签名证书"            $_W_CERT
  print_cmd "${GREEN}edgeboxctl fix-permissions${NC}"                         "修复证书文件的读写权限"                    $_W_CERT
  printf "  %b\n" "${CYAN}示例:${NC}"
  printf "  %b %b\n\n" "${GREEN}edgeboxctl switch-to-domain${NC}" "${CYAN}my.domain.com${NC}"

  # 🌐 SNI 域名轮换
  printf "%b\n" "${YELLOW}■ 🌐 SNI 域名轮换${NC}"
  print_cmd "${GREEN}edgeboxctl sni list${NC}"                      "显示 SNI 域名池状态 (别名: pool)"             $_W_SNI
  print_cmd "${GREEN}edgeboxctl sni test-all${NC}"                  "测试池中所有域名的可用性"                      $_W_SNI
  print_cmd "${GREEN}edgeboxctl sni auto${NC}"                      "智能测试并选择最优 SNI 域名"                   $_W_SNI
  print_cmd "${GREEN}edgeboxctl sni set${NC} ${CYAN}<domain>${NC}"  "手动强制指定一个 SNI 域名"                     $_W_SNI
  printf "  %b\n" "${CYAN}示例:${NC}"
  printf "  %b %b\n\n" "${GREEN}edgeboxctl sni set${NC}" "${CYAN}www.apple.com${NC}"

  # 🔐 Reality 密钥轮换 (v4.3.0: 危险操作需 --confirm)
  printf "%b\n" "${YELLOW}■ 🔐 Reality 密钥轮换${NC}"
  print_cmd "${GREEN}edgeboxctl reality-status${NC}"                                       "查看 Reality 密钥轮换状态"                  $_W_REALITY
  print_cmd "${GREEN}edgeboxctl rotate-reality${NC} ${CYAN}--confirm${NC}"                  "手动轮换 Reality 密钥 (会让所有客户端失效)"   $_W_REALITY
  print_cmd "${GREEN}edgeboxctl rotate-reality${NC} ${CYAN}--confirm --force${NC}"          "强制轮换 (跳过过期检测)"                    $_W_REALITY
  print_cmd "${GREEN}edgeboxctl rotate-sid${NC}"                                            "无感轮换 Reality shortId (7天宽限期)"        $_W_REALITY
  printf "  %b\n" "${CYAN}注：${NC}Reality 密钥不会因时间被破解。除非业务上有需要，否则不必主动轮换。"
  printf "\n"

  # 🧬 流量特征随机化
  printf "%b\n" "${YELLOW}■ 🧬 流量特征随机化${NC}"
  print_cmd "${GREEN}edgeboxctl traffic status${NC}"                                      "查看随机化系统状态和定时任务"    $_W_TRAND
  print_cmd "${GREEN}edgeboxctl traffic reset${NC}"                                       "重置随机化参数为默认值"          $_W_TRAND
  print_cmd "${GREEN}edgeboxctl traffic randomize${NC} ${CYAN}[light|medium|heavy]${NC}"  "执行流量特征随机化，增强隐蔽性"  $_W_TRAND
  printf "  %b\n" "${CYAN}示例:${NC}"
  printf "  %b %b\n" "${GREEN}edgeboxctl traffic randomize${NC}" "${CYAN}medium${NC}"
  printf "  %b\n" "${CYAN}level:${NC}"
  printf "  %b  %b\n" "${CYAN}light(默认)${NC}"  "${DIM}—轻度随机化，仅Hysteria2 仿装站点${NC}"
  printf "  %b  %b\n" "${CYAN}medium${NC}" "${DIM}— 中度随机化，修改 Hysteria2 + Reality 参数${NC}"
  printf "  %b  %b\n\n" "${CYAN}heavy${NC}"  "${DIM}— 重度随机化，修改 Reality + Hysteria2 参数${NC}"

  # 🔗 独立用户订阅URL
  printf "%b\n" "${YELLOW}■ 🔗 独立用户订阅URL${NC}"
  print_cmd "${GREEN}edgeboxctl sub show${NC}"                              "查看用户订阅及已绑定的设备"         $_W_SUB
  print_cmd "${GREEN}edgeboxctl sub issue${NC} ${CYAN}<user> [limit]${NC}"  "为指定用户下发专属订阅链接"       $_W_SUB
  print_cmd "${GREEN}edgeboxctl sub revoke${NC} ${CYAN}<user>${NC}"         "停用指定用户的订阅链接"             $_W_SUB
  print_cmd "${GREEN}edgeboxctl sub limit${NC} ${CYAN}<user> <N>${NC}"      "修改用户的设备上限"                 $_W_SUB
  printf "  %b\n" "${CYAN}示例:${NC}"
  printf "  %b %b\n" "${GREEN}edgeboxctl sub issue${NC}" "${CYAN}alice 5${NC}"
  printf "  %b %b\n\n" "${GREEN}edgeboxctl sub limit${NC}" "${CYAN}alice${NC}"

  # 👥 网络身份配置
  printf "%b\n" "${YELLOW}■ 👥 网络身份配置${NC}"
  print_cmd "${GREEN}edgeboxctl shunt vps${NC}"                                  "VPS 直连出站（默认）"          $_W_SHUNT
  print_cmd "${GREEN}edgeboxctl shunt resi${NC} ${CYAN}'<URL>'${NC}"             "代理全量出站（仅 Xray）"        $_W_SHUNT
  print_cmd "${GREEN}edgeboxctl shunt direct-resi${NC} ${CYAN}'<URL>'${NC}"      "智能分流（白名单直连，其余走代理）" $_W_SHUNT
  print_cmd "${GREEN}edgeboxctl shunt status${NC}"                               "查看当前出站模式及代理健康状态"        $_W_SHUNT
  print_cmd "${GREEN}edgeboxctl shunt whitelist${NC} ${CYAN}{action} [domain]${NC}" "管理白名单【add|remove|reset|list】" $_W_SHUNT
  printf "  %b\n" "${CYAN}示例:${NC}"
  printf "  %b %b\n" "${GREEN}edgeboxctl shunt direct-resi${NC}" "${CYAN}'socks5://user:pass@host:port'${NC}"
  printf "  %b %b\n" "${GREEN}edgeboxctl shunt whitelist add${NC}" "${CYAN}netflix.com${NC}"
  printf "  %b\n" "${CYAN}代理URL格式:${NC}"
  printf "  %b\n" "${CYAN}http://user:pass@host:port${NC}"
  printf "  %b\n" "${CYAN}https://user:pass@host:port${NC}"
  printf "  %b\n" "${CYAN}socks5://user:pass@host:port${NC}"
  printf "  %b\n\n" "${CYAN}socks5://user:pass@host:port?sni=example.com${NC}"

  # 📊 流量与预警
  printf "%b\n" "${YELLOW}■ 📊 流量与预警${NC}"
  print_cmd "${GREEN}edgeboxctl traffic show${NC}"                             "在终端查看流量使用统计"                 $_W_ALERT
  print_cmd "${GREEN}edgeboxctl alert show${NC}"                               "查看当前预警配置"                       $_W_ALERT
  print_cmd "${GREEN}edgeboxctl alert monthly${NC} ${CYAN}<GiB>${NC}"          "设置月度流量预算"                       $_W_ALERT
  print_cmd "${GREEN}edgeboxctl alert steps${NC} ${CYAN}<p1,p2,...>${NC}"      "设置百分比预警阈值 (逗号分隔)"           $_W_ALERT
  print_cmd "${GREEN}edgeboxctl alert telegram${NC} ${CYAN}<token>${NC} ${CYAN}<chat_id>${NC}" "配置 Telegram 通知渠道" $_W_ALERT
  print_cmd "${GREEN}edgeboxctl alert discord${NC} ${CYAN}<webhook_url>${NC}"  "配置 Discord 通知渠道"                  $_W_ALERT
  print_cmd "${GREEN}edgeboxctl alert wechat${NC} ${CYAN}<pushplus_token>${NC}" "配置微信 PushPlus 通知渠道"            $_W_ALERT
  print_cmd "${GREEN}edgeboxctl alert webhook${NC} ${CYAN}<url> [format]${NC}"     "配置通用 Webhook (raw|slack|discord)" $_W_ALERT
  print_cmd "${GREEN}edgeboxctl alert test${NC} ${CYAN}[percent]${NC}"         "模拟触发预警以测试通知渠道"             $_W_ALERT
  print_cmd "${GREEN}edgeboxctl alert silence${NC} ${CYAN}<hours>${NC}"        "临时静默告警 N 小时（仅本地日志，不发外部）" $_W_ALERT
  print_cmd "${GREEN}edgeboxctl alert unsilence${NC}"                          "解除静默"                               $_W_ALERT
  print_cmd "${GREEN}edgeboxctl alert status${NC}"                             "查看告警状态 + 已配置渠道 + 最近告警"   $_W_ALERT
  printf "  %b\n" "${CYAN}示例:${NC}"
  printf "  %b %b\n" "${GREEN}edgeboxctl alert monthly${NC}" "${CYAN}1000${NC}"
  printf "  %b %b\n" "${GREEN}edgeboxctl alert steps${NC}"   "${CYAN}50,80,95${NC}"
  printf "  %b %b %b\n" "${GREEN}edgeboxctl alert telegram${NC}" "${CYAN}<token>${NC}" "${CYAN}<chat_id>${NC}"
  printf "  %b %b\n\n" "${GREEN}edgeboxctl alert test${NC}"  "${CYAN}80${NC}"

  # 🛡️ 协议健康监控 (v4.1.0)
  printf "%b\n" "${YELLOW}■ 🛡️ 协议健康监控${NC}"
  print_cmd "${GREEN}edgeboxctl monitor status${NC}"                "显示协议健康状态摘要"                  $_W_ALERT
  print_cmd "${GREEN}edgeboxctl monitor test${NC}"                  "立即执行一次健康检查"                  $_W_ALERT
  print_cmd "${GREEN}edgeboxctl monitor logs${NC}"                  "查看监控日志最近 50 行"                $_W_ALERT
  print_cmd "${GREEN}edgeboxctl monitor mode${NC} ${CYAN}<monitor|repair|off>${NC}" "设置监控行为模式"     $_W_ALERT
  printf "  %b\n" "${CYAN}默认模式 monitor：${NC}只检测和告警，永远不会自动修改服务或配置"
  printf "  %b\n\n" "${CYAN}repair 模式：${NC}检测到 down 时尝试重启服务（不改配置/防火墙）"

  # ⏰ Cron 定时任务 (v4.2.0)
  printf "%b\n" "${YELLOW}■ ⏰ Cron 定时任务${NC}"
  print_cmd "${GREEN}edgeboxctl cron list${NC}"                     "列出所有 cron 任务及启用状态"          $_W_ALERT
  print_cmd "${GREEN}edgeboxctl cron enable${NC} ${CYAN}<name>${NC}"  "启用某个可选任务"                  $_W_ALERT
  print_cmd "${GREEN}edgeboxctl cron disable${NC} ${CYAN}<name>${NC}" "停用某个可选任务"                  $_W_ALERT
  printf "  %b\n"   "${CYAN}默认启用：${NC}dashboard 刷新 / 流量采集 / 流量告警 / IP 质量检测（仅只读）"
  printf "  %b\n"   "${CYAN}可选启用：${NC}sni-auto / rotate-sid / traffic-randomize-{light,medium,heavy}"
  printf "  %b\n\n" "${CYAN}永不允许：${NC}rotate-reality（密钥轮换只能手动且需 --confirm）"

  # 🧩 配置与维护
  printf "%b\n" "${YELLOW}■ 🧩 配置与维护${NC}"
  print_cmd "${GREEN}edgeboxctl dashboard passcode${NC}"           "重置 Web 控制面板的访问密码"    $_W_CONF
  print_cmd "${GREEN}edgeboxctl alias${NC} ${CYAN}<我的备注>${NC}" "为当前服务器设置一个易记的别名"     $_W_CONF
  print_cmd "${GREEN}edgeboxctl config show${NC}"                  "显示所有协议的 UUID、密码等详细配置"  $_W_CONF
  print_cmd "${GREEN}edgeboxctl config regenerate-uuid${NC}"       "为所有协议重新生成 UUID 和密码"      $_W_CONF
  print_cmd "${GREEN}edgeboxctl backup create${NC}"                "创建当前系统配置的完整备份"          $_W_CONF
  print_cmd "${GREEN}edgeboxctl backup list${NC}"                  "列出所有可用的备份文件"              $_W_CONF
  print_cmd "${GREEN}edgeboxctl backup restore${NC} ${CYAN}<file>${NC}" "从指定备份文件恢复系统配置"    $_W_CONF
  printf "  %b\n" "${CYAN}示例:${NC}"
  printf "  %b %b\n" "${GREEN}edgeboxctl alias${NC}" "${CYAN}\"香港-CN2-主力\"${NC}"
  printf "  %b %b\n\n" "${GREEN}edgeboxctl backup restore${NC}" "${CYAN}edgebox_backup_xxx.tar.gz${NC}"

  # 🔍 诊断与排障
  printf "%b\n" "${YELLOW}■ 🔍 诊断与排障${NC}"
  print_cmd "${GREEN}edgeboxctl debug-ports${NC}"                                        "检查核心端口 (80, 443) 是否被占用" $_W_DEBUG
  print_cmd "${GREEN}edgeboxctl test${NC}"                                               "对各协议入口进行基础连通性测试" $_W_DEBUG
  print_cmd "${GREEN}edgeboxctl test-udp${NC} ${CYAN}<host>${NC} ${CYAN}<port>${NC} ${CYAN}[seconds]${NC}" "使用 iperf3/socat 进行 UDP 连通性简测" $_W_DEBUG
  printf "  %b\n" "${CYAN}示例 (排障流程):${NC}"
  printf "  %b → %b %b → %b\n\n" "${GREEN}edgeboxctl status${NC}" "${GREEN}edgeboxctl logs${NC}" "${CYAN}xray${NC}" "${GREEN}edgeboxctl debug-ports${NC}"

  # 尾部信息
  printf "%b\n" "${CYAN}────────────────────────────────────────────────────────────────"
  printf "  获取更多帮助\n"
  printf "%b\n" "────────────────────────────────────────────────────────────────${NC}"
  printf "  配置文件: /etc/edgebox/config/\n"
  printf "  Web 面板: https://<IP或域名>:8443/traffic/?passcode=<你的密码>\n"
  printf "  订阅链接: https://<IP或域名>:8443/sub-<token>\n"
  printf "  查看日志: tail -f /var/log/edgebox-install.log\n"
  
  ;;

  # v4.6.0-rc4 (审核 P1#8): 未知顶层命令必须返回非零，否则自动化无法判断参数是否正确。
  #   (dispatch 在顶层而非函数内，故用 exit 2 而非 return 2。)
  *)
    log_error "未知命令: ${1:-}"
    echo "运行 'edgeboxctl help' 查看可用命令"
    exit 2
    ;;

esac

# v4.6.0-rc4 (审核 P1#2): 显式 propagate case 退出码
# 旧版本: case 后还有 if [[ BASH_SOURCE... ]] load_config_once, 让脚本最终 exit 0
# 新版本: 直接 exit "$?" — 让 case 分支函数的 return 码成为脚本退出码
_eb_dispatch_rc=$?
exit "$_eb_dispatch_rc"
